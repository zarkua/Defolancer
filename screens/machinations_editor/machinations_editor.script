local function copy_table(value)
	if type(value) ~= "table" then
		return value
	end

	local out = {}
	for key, item in pairs(value) do
		out[key] = copy_table(item)
	end
	return out
end

local function clamp(value, min_value, max_value)
	if value < min_value then
		return min_value
	end
	if value > max_value then
		return max_value
	end
	return value
end

local function get_canvas_rect(viewport_w, viewport_h)
	viewport_w = viewport_w or DEFAULT_VIEWPORT_W
	viewport_h = viewport_h or DEFAULT_VIEWPORT_H

	local left = PAGE_MARGIN + LEFT_PANEL_WIDTH + CONTENT_GAP
	local right = viewport_w - PAGE_MARGIN - RIGHT_PANEL_WIDTH - CONTENT_GAP
	local bottom = PAGE_MARGIN + BOTTOM_BAR_HEIGHT + ANALYTICS_HEIGHT + CONTENT_GAP
	local top = viewport_h - PAGE_MARGIN - TOP_BAR_HEIGHT - CONTENT_GAP

	if right - left < 220 then
		local center_x = viewport_w * 0.5
		left = center_x - 110
		right = center_x + 110
	end
	if top - bottom < 220 then
		local center_y = viewport_h * 0.5
		bottom = center_y - 110
		top = center_y + 110
	end

	return left, right, bottom, top
end

local function is_inside_canvas(screen_x, screen_y, viewport_w, viewport_h)
	local left, right, bottom, top = get_canvas_rect(viewport_w, viewport_h)
	return screen_x >= left and screen_x <= right and screen_y >= bottom and screen_y <= top
end

local function join_lines(lines)
	if #lines == 0 then
		return ""
	end
	return table.concat(lines, "\n")
end

local function file_exists(path)
	local file = io.open(path, "rb")
	if file then
		file:close()
		return true
	end

	if type(sys) == "table" and type(sys.load_resource) == "function" then
		local resource_path = path
		if string.sub(resource_path, 1, 1) ~= "/" then
			resource_path = "/" .. resource_path
		end
		local data = sys.load_resource(resource_path)
		return data ~= nil
	end

	return false
end

local function is_html5_runtime()
	local sys_info = sys.get_sys_info()
	return sys_info ~= nil and sys_info.system_name == "HTML5"
end

local function write_text_file(path, text)
	local file, open_err = io.open(path, "wb")
	if not file then
		return nil, "open failed: " .. tostring(open_err)
	end
	local ok, write_err = file:write(text)
	file:close()
	if not ok then
		return nil, "write failed: " .. tostring(write_err)
	end
	return true
end

local function load_diagram_from_path(path)
	local diagram, err = Io.decode_diagram_file(path)
	if not diagram then
		return nil, err
	end
	return diagram
end

local function get_library_entry(diagram_key)
	for _, item in ipairs(DIAGRAM_LIBRARY) do
		if item.key == diagram_key then
			return item
		end
	end
	return nil
end

local function detect_library_key_from_path(path)
	for _, item in ipairs(DIAGRAM_LIBRARY) do
		if item.path == path then
			return item.key
		end
	end
	return nil
end

local function build_blank_diagram()
	if file_exists(BLANK_DIAGRAM_PATH) then
		local diagram = load_diagram_from_path(BLANK_DIAGRAM_PATH)
		if diagram ~= nil then
			return copy_table(diagram)
		end
	end

	return {
		name = "Machinations",
		author = "Joris Dormans",
		play_mode = types.PLAY_MODE.HEADLESS,
		distribution_mode = "fixed speed",
		interval = 1,
		dice = "D6",
		skill = "",
		multiplayer = "",
		strategy = "",
		width = 600,
		height = 560,
		number_of_runs = DEFAULT_NUMBER_OF_RUNS,
		visible_runs = DEFAULT_VISIBLE_RUNS,
		nodes = {},
		connections = {},
		["end"] = {
			stop_when_idle = true,
			max_ticks = 1000,
		},
		editor_positions = {},
	}
end

local function extract_editor_positions(diagram)
	local positions = {}
	if type(diagram.editor_positions) ~= "table" then
		return positions
	end

	for node_id, pos in pairs(diagram.editor_positions) do
		if type(pos) == "table" and type(pos.x) == "number" and type(pos.y) == "number" then
			positions[node_id] = {
				x = pos.x,
				y = pos.y,
			}
		end
	end

	return positions
end

local function apply_auto_positions(diagram, positions)
	local row_size = 4
	local x_step = 176
	local y_step = 126
	for index, node in ipairs(diagram.nodes or {}) do
		if positions[node.id] == nil then
			local row = math.floor((index - 1) / row_size)
			local col = (index - 1) % row_size
			local first_in_row = row * row_size + 1
			local remaining = #(diagram.nodes or {}) - first_in_row + 1
			local count_in_row = math.min(row_size, math.max(remaining, 1))
			local start_x = -((count_in_row - 1) * x_step) * 0.5
			positions[node.id] = {
				x = start_x + col * x_step,
				y = 120 - row * y_step,
			}
		end
	end
end

node_id_exists = function(diagram, node_id)
	for _, node in ipairs((diagram and diagram.nodes) or {}) do
		if node.id == node_id then
			return true
		end
	end
	for _, visual_node in ipairs((diagram and diagram.legacy_visual_nodes) or {}) do
		if visual_node.id == node_id then
			return true
		end
	end
	return false
end

connection_id_exists = function(diagram, connection_id)
	for _, connection in ipairs((diagram and diagram.connections) or {}) do
		if connection.id == connection_id then
			return true
		end
	end
	for _, connection in ipairs((diagram and diagram.legacy_visual_connections) or {}) do
		if connection.id == connection_id then
			return true
		end
	end
	return false
end

local function find_node_index(diagram, node_id)
	for index, node in ipairs(diagram.nodes or {}) do
		if node.id == node_id then
			return index
		end
	end
	return nil
end

local function find_visual_node_index(diagram, node_id)
	for index, visual_node in ipairs(diagram.legacy_visual_nodes or {}) do
		if visual_node.id == node_id then
			return index
		end
	end
	return nil
end

local function remove_connections_for_node(diagram, node_id)
	for index = #diagram.connections, 1, -1 do
		local connection = diagram.connections[index]
		if connection.from == node_id or connection.to == node_id then
			table.remove(diagram.connections, index)
		end
	end
	for index = #(diagram.legacy_visual_connections or {}), 1, -1 do
		local connection = diagram.legacy_visual_connections[index]
		if connection.from == node_id or connection.to == node_id then
			table.remove(diagram.legacy_visual_connections, index)
		end
	end
end

local function set_visual_anchor_position(visual_node, center_x, center_y)
	local width, height = get_payload_dimensions(nil, visual_node)
	local symbol = tostring(visual_node.symbol or "")
	if symbol == "Chart" or symbol == "GroupBox" then
		visual_node.x = center_x - width * 0.5
		visual_node.y = center_y + height * 0.5
	else
		visual_node.x = center_x
		visual_node.y = center_y
	end
end

local function setup_serials(self)
	self.next_node_serial = 1
	self.next_connection_serial = 1

	for _, node in ipairs(self.design_diagram.nodes or {}) do
		local suffix = tonumber(string.match(node.id or "", "_(%d+)$"))
		if suffix ~= nil and suffix >= self.next_node_serial then
			self.next_node_serial = suffix + 1
		end
	end
	for _, visual_node in ipairs(self.design_diagram.legacy_visual_nodes or {}) do
		local suffix = tonumber(string.match(visual_node.id or "", "_(%d+)$"))
		if suffix ~= nil and suffix >= self.next_node_serial then
			self.next_node_serial = suffix + 1
		end
	end

	for _, connection in ipairs(self.design_diagram.connections or {}) do
		local suffix = tonumber(string.match(connection.id or "", "_(%d+)$"))
		if suffix ~= nil and suffix >= self.next_connection_serial then
			self.next_connection_serial = suffix + 1
		end
	end
	for _, connection in ipairs(self.design_diagram.legacy_visual_connections or {}) do
		local suffix = tonumber(string.match(connection.id or "", "_(%d+)$"))
		if suffix ~= nil and suffix >= self.next_connection_serial then
			self.next_connection_serial = suffix + 1
		end
	end
end

local function restart_runtime(self)
	local state, err = Engine.init(self.design_diagram, {
		seed = self.seed,
		play_mode = types.PLAY_MODE.STEP,
	})
	if not state then
		self.runtime_state = nil
		self.status_line = "Runtime init error: " .. tostring(err)
		self.autoplay = false
		return false
	end

	self.runtime_state = state
	self.last_step_summary = nil
	self.last_batch_chart_points = nil
	return true
end

local function get_runtime_node(self, node_id)
	if not self.runtime_state then
		return nil
	end
	return self.runtime_state.nodes[node_id]
end

local function screen_to_world(self, screen_x, screen_y, viewport_w, viewport_h)
	viewport_w = viewport_w or self.viewport_w
	viewport_h = viewport_h or self.viewport_h
	local left, right, bottom, top = get_canvas_rect(viewport_w, viewport_h)
	local center_x = (left + right) * 0.5
	local center_y = (bottom + top) * 0.5
	local world_x = (screen_x - center_x) / self.camera_zoom + self.camera_x
	local world_y = (screen_y - center_y) / self.camera_zoom + self.camera_y
	return world_x, world_y
end

local function world_to_screen(self, world_x, world_y, viewport_w, viewport_h)
	viewport_w = viewport_w or self.viewport_w
	viewport_h = viewport_h or self.viewport_h
	local left, right, bottom, top = get_canvas_rect(viewport_w, viewport_h)
	local center_x = (left + right) * 0.5
	local center_y = (bottom + top) * 0.5
	local screen_x = (world_x - self.camera_x) * self.camera_zoom + center_x
	local screen_y = (world_y - self.camera_y) * self.camera_zoom + center_y
	return screen_x, screen_y
end

local function find_node_at(self, world_x, world_y)
	for index = #(self.design_diagram.legacy_visual_nodes or {}), 1, -1 do
		local visual_node = self.design_diagram.legacy_visual_nodes[index]
		if tostring(visual_node.symbol or "") ~= "GroupBox" then
			local width, height = get_payload_dimensions(nil, visual_node)
			local center_x, center_y = resolve_visual_anchor_position(visual_node, width, height)
			local dx = math.abs(world_x - center_x)
			local dy = math.abs(world_y - center_y)
			if dx <= width * 0.5 and dy <= height * 0.5 then
				return visual_node.id
			end
		end
	end

	for index = #self.design_diagram.nodes, 1, -1 do
		local node = self.design_diagram.nodes[index]
		local pos = self.editor_positions[node.id]
		if pos ~= nil then
			local node_type = node.type
			if type(node.data) == "table" and node.data.ap_functional == true then
				node_type = "artificial_player"
			end
			local width, height = get_payload_dimensions(node_type)
			local half_w = width * 0.5
			local half_h = height * 0.5
			local dx = math.abs(world_x - pos.x)
			local dy = math.abs(world_y - pos.y)
			if dx <= half_w and dy <= half_h then
				return node.id
			end
		end
	end

	for index = #(self.design_diagram.legacy_visual_nodes or {}), 1, -1 do
		local visual_node = self.design_diagram.legacy_visual_nodes[index]
		if tostring(visual_node.symbol or "") == "GroupBox" then
			local width, height = get_payload_dimensions(nil, visual_node)
			local center_x, center_y = resolve_visual_anchor_position(visual_node, width, height)
			local dx = math.abs(world_x - center_x)
			local dy = math.abs(world_y - center_y)
			if dx <= width * 0.5 and dy <= height * 0.5 then
				return visual_node.id
			end
		end
	end

	return nil
end

local function find_handle_at(self, screen_x, screen_y, viewport_w, viewport_h)
	local box_scale = clamp(self.camera_zoom * 0.85, 0.7, 1.2)
	local radius = LINK_HANDLE_RADIUS * box_scale

	for index = #self.design_diagram.nodes, 1, -1 do
		local node = self.design_diagram.nodes[index]
		local pos = self.editor_positions[node.id]
		if pos ~= nil then
			local node_type = node.type
			if type(node.data) == "table" and node.data.ap_functional == true then
				node_type = "artificial_player"
			end
			local width = get_payload_dimensions(node_type)
			local node_screen_x, node_screen_y = world_to_screen(self, pos.x, pos.y, viewport_w, viewport_h)
			local handle_x = node_screen_x + width * 0.5 + 10
			local handle_y = node_screen_y
			local dx = screen_x - handle_x
			local dy = screen_y - handle_y
			if (dx * dx + dy * dy) <= (radius * radius) then
				return node.id
			end
		end
	end
	return nil
end

