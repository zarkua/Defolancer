local function distance_to_segment(point_x, point_y, x1, y1, x2, y2)
	local dx = x2 - x1
	local dy = y2 - y1
	local length_sq = dx * dx + dy * dy
	if length_sq <= 0.0001 then
		local px = point_x - x1
		local py = point_y - y1
		return math.sqrt(px * px + py * py)
	end

	local t = ((point_x - x1) * dx + (point_y - y1) * dy) / length_sq
	t = clamp(t, 0, 1)
	local nearest_x = x1 + dx * t
	local nearest_y = y1 + dy * t
	local diff_x = point_x - nearest_x
	local diff_y = point_y - nearest_y
	return math.sqrt(diff_x * diff_x + diff_y * diff_y)
end

local function find_connection_at(self, world_x, world_y)
	local positions = build_position_lookup(self)
	local threshold = clamp(12 / math.max(self.camera_zoom, 0.2), 8, 22)
	local best_distance = nil
	local best_id = nil

	local function test_points(connection_id, points)
		if type(points) ~= "table" or #points < 2 then
			return
		end
		for index = 1, #points - 1 do
			local from_point = points[index]
			local to_point = points[index + 1]
			local distance = distance_to_segment(
				world_x,
				world_y,
				tonumber(from_point.x) or 0,
				tonumber(from_point.y) or 0,
				tonumber(to_point.x) or 0,
				tonumber(to_point.y) or 0
			)
			if distance <= threshold and (best_distance == nil or distance < best_distance) then
				best_distance = distance
				best_id = connection_id
			end
		end
	end

	for _, connection in ipairs(self.design_diagram.connections or {}) do
		local from_pos = positions[connection.from]
		local to_pos = positions[connection.to]
		if from_pos ~= nil and to_pos ~= nil then
			test_points(
				connection.id,
				build_edge_points(from_pos, to_pos, connection.data and connection.data.legacy_points or nil, connection.flow_mode)
			)
		end
	end

	for _, connection in ipairs(self.design_diagram.legacy_visual_connections or {}) do
		if connection.floating and type(connection.points) == "table" and #connection.points >= 2 then
			test_points(connection.id, connection.points)
		else
			local from_pos = connection.from and positions[connection.from] or nil
			local to_pos = connection.to and positions[connection.to] or nil
			if from_pos ~= nil and to_pos ~= nil then
				test_points(connection.id, build_edge_points(from_pos, to_pos, connection.points, types.FLOW_MODE.PUSH))
			end
		end
	end

	return best_id
end

local function describe_connection_type(connection)
	if connection == nil then
		return "-"
	end
	if connection.type == types.CONNECTION.STATE then
		return "state"
	end
	return "resource"
end

local function describe_connection_label(connection)
	if connection == nil then
		return "-"
	end
	if type(connection.label) == "string" and connection.label ~= "" then
		return connection.label
	end
	if type(connection.data) == "table" and type(connection.data.legacy_label) == "string" and connection.data.legacy_label ~= "" then
		return connection.data.legacy_label
	end
	if connection.type == types.CONNECTION.STATE then
		return string.format("%s %s %s", tostring(connection.source_field or "resources"), tostring(connection.comparator or ">"), tostring(connection.value or 0))
	end
	return tostring(connection.amount or 1)
end

