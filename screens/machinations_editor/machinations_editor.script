	local icons = {
		source = "/\\",
		pool = "O",
		drain = "\\/",
		converter = ">|",
		trader = "><",
		gate = "<>",
		register = "8",
		delay = "[]",
		queue = "[]",
		end_condition = "!",
		artificial_player = "AP",
		legacy_chart = "CH",
		legacy_textlabel = "T",
		legacy_groupbox = "GB",
		legacy_artificialplayer = "AP",
		legacy_endcondition = "!",
	}
	return icons[node_type] or "N"
end

