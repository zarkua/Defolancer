		pool = "pool",
		drain = "drain",
		converter = "converter",
		trader = "trader",
		gate = "gate",
		register = "register",
		delay = "delay",
		queue = "delay",
		end_condition = "endcondition",
		artificial_player = "artificialplayer",
		legacy_chart = "chart",
		legacy_textlabel = "textlabel",
		legacy_groupbox = "groupbox",
		legacy_artificialplayer = "artificialplayer",
		legacy_endcondition = "endcondition",
	}
	return shapes[node_type] or "rect"
end

local function get_legacy_visual_value(visual_node)
	local symbol = tostring(visual_node.symbol or "")
	if symbol == "Chart" then
		return string.format("X:%s  Y:%s", tostring(visual_node.scale_x or "-"), tostring(visual_node.scale_y or "-"))
	end
	if symbol == "ArtificialPlayer" then
		return string.format("APT:%s", tostring(visual_node.actions_per_turn or 1))
	end
	if symbol == "EndCondition" then
		return "end"
	end
	if symbol == "GroupBox" or symbol == "TextLabel" then
		return ""
	end
	return symbol
end

get_payload_dimensions = function(node_type, visual_node)
	if visual_node ~= nil then
		local symbol = tostring(visual_node.symbol or "")
		if symbol == "TextLabel" then
			return math.max((#tostring(visual_node.caption or "") * 8) + 32, 84), 28
		end
		if symbol == "GroupBox" or symbol == "Chart" then
			return math.max(tonumber(visual_node.width) or 132, 96), math.max(tonumber(visual_node.height) or 72, 56)
		end
		if symbol == "ArtificialPlayer" or symbol == "EndCondition" then
			return 90, 56
		end
		return math.max(tonumber(visual_node.width) or 132, 72), math.max(tonumber(visual_node.height) or 72, 42)
	end
	if node_type == types.NODE.SOURCE or node_type == types.NODE.DRAIN or node_type == types.NODE.GATE then
		return 94, 72
	end
	if node_type == types.NODE.POOL then
		return 112, 92
	end
	if node_type == types.NODE.CONVERTER or node_type == types.NODE.TRADER then
		return 118, 82
	end
	if node_type == types.NODE.REGISTER then
		return 92, 64
	end
	if node_type == "artificial_player" then
		return 92, 72
	end
	if node_type == types.NODE.DELAY or node_type == types.NODE.QUEUE then
		return 104, 92
	end
	if node_type == types.NODE.END_CONDITION then
		return 92, 74
	end
	return 156, 64
end

resolve_visual_anchor_position = function(visual_node, width, height)
	local x = tonumber(visual_node.x) or 0
	local y = tonumber(visual_node.y) or 0
	local symbol = tostring(visual_node.symbol or "")
	if symbol == "Chart" or symbol == "GroupBox" then
		x = x + width * 0.5
		y = y - height * 0.5
	end
	return x, y
end

local function get_node_value_text(node, runtime_node)
	if node.type == types.NODE.REGISTER then
		local value = runtime_node and runtime_node.register_value or node.register_value or 0
		if type(node.data) == "table" and node.data.ap_functional == true then
			return string.format("APT:%d", math.floor(tonumber(node.actions_per_turn) or 1))
		end
		return string.format("v:%.2f", tonumber(value) or 0)
	end
	if node.type == types.NODE.DELAY or node.type == types.NODE.QUEUE then
		return string.format("t:%d", math.floor(tonumber(node.delay_ticks) or 1))
	end
	local value = runtime_node and runtime_node.resources or node.initial_resources or 0
	return string.format("r:%d", math.floor(tonumber(value) or 0))
end

local function get_ap_script_preset_index(node)
	local preset_key = nil
	if type(node.data) == "table" and type(node.data.ap_script_preset) == "string" then
		preset_key = node.data.ap_script_preset
	end
	if preset_key ~= nil then
		for index, preset in ipairs(AP_SCRIPT_PRESETS) do
			if preset.key == preset_key then
				return index
			end
		end
	end

	local script = tostring(node.script or "")
	for index, preset in ipairs(AP_SCRIPT_PRESETS) do
		if preset.script == script then
			return index
		end
	end
	return 1
end

local function get_ap_script_display(node)
	local preset = AP_SCRIPT_PRESETS[get_ap_script_preset_index(node)]
	if preset == nil then
		return "-"
	end
	if preset.script == "" then
		return preset.label
	end
	return string.format("%s: %s", preset.label, preset.script)
end

local function set_ap_script_preset(node, direction)
	node.data = node.data or {}
	local next_index = get_ap_script_preset_index(node) + direction
	if next_index < 1 then
		next_index = #AP_SCRIPT_PRESETS
	elseif next_index > #AP_SCRIPT_PRESETS then
		next_index = 1
	end

	local preset = AP_SCRIPT_PRESETS[next_index]
	node.data.ap_script_preset = preset.key
	node.script = preset.script
	return true, "Script: " .. preset.label
end

local function reverse_points(points)
	local reversed = {}
	for index = #points, 1, -1 do
		reversed[#reversed + 1] = {
			x = points[index].x,
			y = points[index].y,
		}
	end
	return reversed
end

build_edge_points = function(from_pos, to_pos, legacy_points, flow_mode)
	local points = {}
	if from_pos ~= nil then
		points[#points + 1] = { x = from_pos.x, y = from_pos.y }
	end
	for _, point in ipairs(legacy_points or {}) do
		points[#points + 1] = {
			x = tonumber(point.x) or 0,
			y = tonumber(point.y) or 0,
		}
	end
	if to_pos ~= nil then
		points[#points + 1] = { x = to_pos.x, y = to_pos.y }
	end
	if flow_mode == types.FLOW_MODE.PULL then
		return reverse_points(points)
	end
	return points
end

build_position_lookup = function(self)
	local lookup = {}
	for node_id, pos in pairs(self.editor_positions or {}) do
		lookup[node_id] = {
			x = tonumber(pos.x) or 0,
			y = tonumber(pos.y) or 0,
		}
	end
	for _, visual_node in ipairs(self.design_diagram.legacy_visual_nodes or {}) do
		local width, height = get_payload_dimensions(nil, visual_node)
		local x, y = resolve_visual_anchor_position(visual_node, width, height)
		lookup[visual_node.id] = {
			x = x,
			y = y,
		}
	end
	return lookup
end

local function compose_hud_text(self)
	local tick = 0
	if self.runtime_state ~= nil then
		tick = self.runtime_state.tick
	end
	return string.format(
		"Tick %d | Zoom %.2f | Tool %s",
		tick,
		self.camera_zoom,
		self.active_tool or "select"
	)
end

local function compose_status_text(self)
	local selected = self.selected_node_id or "-"
	local selected_connection = self.selected_connection_id or "-"
	local link = self.link_from_node_id or "-"
	local status_line = self.status_line or ""
	local selected_node = get_design_node(self.design_diagram, selected)
	local selected_visual = get_visual_node(self.design_diagram, selected)
	local selected_connection_object = get_design_connection(self.design_diagram, selected_connection) or get_visual_connection(self.design_diagram, selected_connection)
	local node_type = "-"
	local trigger_mode = "-"
	local rate = 0
	local capacity = 0
	if selected_node ~= nil then
		node_type = selected_node.type or "-"
		trigger_mode = selected_node.trigger_mode or "-"
		rate = tonumber(selected_node.rate) or 0
		capacity = tonumber(selected_node.capacity) or -1
	end

	local runtime_node = get_runtime_node(self, selected)
	local resources = 0
	if runtime_node ~= nil then
		resources = tonumber(runtime_node.resources) or 0
	end

	local graph_name = self.design_diagram.name or "Machinations"
	local graph_author = self.design_diagram.author or "-"
	local time_mode = "asynchronous"
	if self.design_diagram.play_mode == types.PLAY_MODE.INTERACTIVE then
		time_mode = "turn-based"
	end

	local lines = {
		string.format("Name          %s", graph_name),
		string.format("Author        %s", graph_author),
		string.format("Time Mode     %s", time_mode),
		string.format("Interval      %.1f", tonumber(self.design_diagram.interval) or 1),
		string.format("Distribution  %s", self.design_diagram.distribution_mode or "fixed speed"),
		string.format("Color Coding  %s", self.design_diagram.color_coding and "on" or "off"),
		string.format("Dice          %s", self.design_diagram.dice or "D6"),
		string.format("Skill         %s", self.design_diagram.skill or "-"),
		string.format("Multiplayer   %s", self.design_diagram.multiplayer or "-"),
		string.format("Strategy      %s", self.design_diagram.strategy or "-"),
		string.format("Width         %d", math.floor(tonumber(self.design_diagram.width) or 600)),
		string.format("Height        %d", math.floor(tonumber(self.design_diagram.height) or 560)),
	}

	if selected_node ~= nil then
		table.insert(lines, 1, string.format("Link          %s", link))
		table.insert(lines, 1, string.format("Resources     %d", math.floor(resources)))
		table.insert(lines, 1, string.format("Capacity      %d", math.floor(capacity)))
		table.insert(lines, 1, string.format("Rate          %d", math.floor(rate)))
		table.insert(lines, 1, string.format("Trigger       %s", trigger_mode))
		table.insert(lines, 1, string.format("Selection     %s", selected))
		table.insert(lines, 2, string.format("Node Type     %s", node_type))
	elseif selected_visual ~= nil then
		table.insert(lines, 1, string.format("Link          %s", link))
		table.insert(lines, 1, string.format("Selection     %s", selected))
		table.insert(lines, 2, string.format("Node Type     legacy_%s", string.lower(tostring(selected_visual.symbol or "node"))))
	elseif selected_connection_object ~= nil then
		table.insert(lines, 1, string.format("Connection    %s", selected_connection))
		table.insert(lines, 2, string.format("Conn Type     %s", describe_connection_type(selected_connection_object)))
		table.insert(lines, 3, string.format("From          %s", tostring(selected_connection_object.from or "-")))
		table.insert(lines, 4, string.format("To            %s", tostring(selected_connection_object.to or "-")))
	end

	if status_line ~= "" then
		if #status_line > 88 then
			status_line = string.sub(status_line, 1, 85) .. "..."
		end
		lines[#lines + 1] = ""
		lines[#lines + 1] = "Status"
		lines[#lines + 1] = status_line
	end

	return table.concat(lines, "\n")
end

local function encode_command_part(value)
	if value == nil then
		return "-"
	end
	local text = tostring(value)
	text = string.gsub(text, ":", "_")
	return text
end

local function make_cycle_command(scope, target_id, key, direction)
	return table.concat({
		"prop_cycle",
		scope,
		encode_command_part(target_id),
		key,
		tostring(direction or 1),
	}, ":")
end

local function make_adjust_command(scope, target_id, key, delta)
	return table.concat({
		"prop_adjust",
		scope,
		encode_command_part(target_id),
		key,
		tostring(delta or 0),
	}, ":")
end

local function make_toggle_command(scope, target_id, key)
	return table.concat({
		"prop_toggle",
		scope,
		encode_command_part(target_id),
		key,
	}, ":")
end

local function cycle_value(current_value, values, direction)
	local size = #values
	if size == 0 then
		return current_value
	end

	local index = 1
	for candidate_index, candidate in ipairs(values) do
		if candidate == current_value then
			index = candidate_index
			break
		end
	end

	local step = direction or 1
	local next_index = ((index - 1 + step) % size) + 1
	return values[next_index]
end

local function normalize_graph_time_mode(diagram)
	if type(diagram.time_mode) == "string" and diagram.time_mode ~= "" then
		return diagram.time_mode
	end
	if diagram.play_mode == types.PLAY_MODE.INTERACTIVE then
		return "turn_based"
	end
	return "asynchronous"
end

local function build_inspector_payload(self)
	local payload = {
		title = "Machinations [Graph]",
		fields = {},
		status_line = self.status_line or "",
	}

	local function push(label, value, options)
		payload.fields[#payload.fields + 1] = {
			label = label,
			value = tostring(value),
			left_command = options and options.left_command or nil,
			right_command = options and options.right_command or nil,
			click_command = options and options.click_command or nil,
			editable = options and options.editable == true or false,
		}
	end

	local selected_ids = get_selected_node_ids(self)
	if #selected_ids > 1 then
		payload.title = string.format("Machinations [Selection x%d]", #selected_ids)
		push("Selection", #selected_ids)
		push("Primary", self.selected_node_id or selected_ids[1] or "-")
		push("Runs", self.number_of_runs or DEFAULT_NUMBER_OF_RUNS)
		push("Visible Runs", self.visible_runs or DEFAULT_VISIBLE_RUNS)
		push("Width", math.floor(tonumber(self.design_diagram.width) or 600))
		push("Height", math.floor(tonumber(self.design_diagram.height) or 560))
		return payload
	end

	local selected_node = get_design_node(self.design_diagram, self.selected_node_id)
	if selected_node ~= nil then
		local runtime_node = get_runtime_node(self, selected_node.id)
		local is_artificial_player = type(selected_node.data) == "table" and selected_node.data.ap_functional == true
		payload.title = "Machinations [" .. selected_node.id .. "]"
		push("Name", selected_node.id)
		push("Node Type", is_artificial_player and "artificial_player" or (selected_node.type or "-"))
		push(
			"Activation",
			selected_node.data and selected_node.data.legacy_activation_mode or selected_node.trigger_mode or "-",
			{
				left_command = make_cycle_command("node", selected_node.id, "trigger_mode", -1),
				right_command = make_cycle_command("node", selected_node.id, "trigger_mode", 1),
				editable = true,
			}
		)
		if not is_artificial_player then
			push(
				"Rate",
				math.floor(tonumber(selected_node.rate) or 0),
				{
					left_command = make_adjust_command("node", selected_node.id, "rate", -1),
					right_command = make_adjust_command("node", selected_node.id, "rate", 1),
					editable = true,
				}
			)
			push(
				"Capacity",
				math.floor(tonumber(selected_node.capacity) or -1),
				{
					left_command = make_adjust_command("node", selected_node.id, "capacity", -5),
					right_command = make_adjust_command("node", selected_node.id, "capacity", 5),
					editable = true,
				}
			)
		else
			push(
				"Actions/turn",
				math.floor(tonumber(selected_node.actions_per_turn) or 1),
				{
					left_command = make_adjust_command("node", selected_node.id, "actions_per_turn", -1),
					right_command = make_adjust_command("node", selected_node.id, "actions_per_turn", 1),
					editable = true,
				}
			)
			push(
				"Script",
				get_ap_script_display(selected_node),
				{
					left_command = make_cycle_command("node", selected_node.id, "script", -1),
					right_command = make_cycle_command("node", selected_node.id, "script", 1),
					click_command = make_cycle_command("node", selected_node.id, "script", 1),
					editable = true,
				}
			)
		end
		if selected_node.type == types.NODE.REGISTER and not is_artificial_player then
			push(
				"Value",
				math.floor(tonumber(runtime_node and runtime_node.register_value or selected_node.register_value or 0)),
				{
					left_command = make_adjust_command("node", selected_node.id, "register_value", -1),
					right_command = make_adjust_command("node", selected_node.id, "register_value", 1),
					editable = true,
				}
			)
		elseif not is_artificial_player then
			push(
				"Resources",
				math.floor(tonumber(runtime_node and runtime_node.resources or selected_node.initial_resources or 0)),
				{
					left_command = make_adjust_command("node", selected_node.id, "initial_resources", -1),
					right_command = make_adjust_command("node", selected_node.id, "initial_resources", 1),
					editable = true,
				}
			)
		end
		push("Link", self.link_from_node_id or "-")
		if type(selected_node.data) == "table" then
			if selected_node.data.legacy_caption and selected_node.data.legacy_caption ~= "" then
				push("Caption", selected_node.data.legacy_caption)
			end
			if selected_node.data.legacy_pull_mode and selected_node.data.legacy_pull_mode ~= "" then
				push(
					"Pull Mode",
					selected_node.data.legacy_pull_mode,
					{
						left_command = make_cycle_command("node", selected_node.id, "pull_mode", -1),
						right_command = make_cycle_command("node", selected_node.id, "pull_mode", 1),
						editable = true,
					}
				)
			end
			if selected_node.data.legacy_actions ~= nil then
				push(
					"Actions",
					selected_node.data.legacy_actions,
					{
						left_command = make_adjust_command("node", selected_node.id, "legacy_actions", -1),
						right_command = make_adjust_command("node", selected_node.id, "legacy_actions", 1),
						editable = true,
					}
				)
			end
			if selected_node.data.legacy_gate_type and selected_node.data.legacy_gate_type ~= "" then
				push(
					"Gate Type",
					selected_node.data.legacy_gate_type,
					{
						left_command = make_cycle_command("node", selected_node.id, "gate_type", -1),
						right_command = make_cycle_command("node", selected_node.id, "gate_type", 1),
						editable = true,
					}
				)
			end
			if selected_node.data.legacy_delay_type and selected_node.data.legacy_delay_type ~= "" then
				push(
					"Delay Type",
					selected_node.data.legacy_delay_type,
					{
						left_command = make_cycle_command("node", selected_node.id, "delay_type", -1),
						right_command = make_cycle_command("node", selected_node.id, "delay_type", 1),
						editable = true,
					}
				)
			end
			if selected_node.data.legacy_display_capacity ~= nil then
				push(
					"Display Cap.",
					selected_node.data.legacy_display_capacity,
					{
						left_command = make_adjust_command("node", selected_node.id, "display_capacity", -1),
						right_command = make_adjust_command("node", selected_node.id, "display_capacity", 1),
						editable = true,
					}
				)
			end
			if selected_node.data.legacy_min ~= nil then
				push(
					"Min",
					selected_node.data.legacy_min,
					{
						left_command = make_adjust_command("node", selected_node.id, "legacy_min", -1),
						right_command = make_adjust_command("node", selected_node.id, "legacy_min", 1),
						editable = true,
					}
				)
			end
			if selected_node.data.legacy_max ~= nil then
				push(
					"Max",
					selected_node.data.legacy_max,
					{
						left_command = make_adjust_command("node", selected_node.id, "legacy_max", -1),
						right_command = make_adjust_command("node", selected_node.id, "legacy_max", 1),
						editable = true,
					}
				)
			end
			if selected_node.data.legacy_step ~= nil then
				push(
					"Step",
					selected_node.data.legacy_step,
					{
						left_command = make_adjust_command("node", selected_node.id, "legacy_step", -1),
						right_command = make_adjust_command("node", selected_node.id, "legacy_step", 1),
						editable = true,
					}
				)
			end
			if selected_node.data.register_expression and selected_node.data.register_expression ~= "" then
				push("Formula", selected_node.data.register_expression)
			end
			if selected_node.data.legacy_resource_color and selected_node.data.legacy_resource_color ~= "" then
				push(
					"Res Color",
					selected_node.data.legacy_resource_color,
					{
						left_command = make_cycle_command("node", selected_node.id, "resource_color", -1),
						right_command = make_cycle_command("node", selected_node.id, "resource_color", 1),
						editable = true,
					}
				)
			end
		end
		return payload
	end

	local selected_visual = get_visual_node(self.design_diagram, self.selected_node_id)
	if selected_visual ~= nil then
		payload.title = "Machinations [" .. selected_visual.id .. "]"
		push("Name", selected_visual.id)
		push("Node Type", "legacy_" .. string.lower(tostring(selected_visual.symbol or "node")))
		push("Caption", selected_visual.caption or "")
		push(
			"Width",
			math.floor(tonumber(selected_visual.width) or 0),
			{
				left_command = make_adjust_command("visual", selected_visual.id, "width", -20),
				right_command = make_adjust_command("visual", selected_visual.id, "width", 20),
				editable = true,
			}
		)
		push(
			"Height",
			math.floor(tonumber(selected_visual.height) or 0),
			{
				left_command = make_adjust_command("visual", selected_visual.id, "height", -20),
				right_command = make_adjust_command("visual", selected_visual.id, "height", 20),
				editable = true,
			}
		)
		if selected_visual.actions_per_turn ~= nil then
			push(
				"Actions",
				selected_visual.actions_per_turn,
				{
					left_command = make_adjust_command("visual", selected_visual.id, "actions_per_turn", -1),
					right_command = make_adjust_command("visual", selected_visual.id, "actions_per_turn", 1),
					editable = true,
				}
			)
		end
		if selected_visual.gate_type ~= nil and selected_visual.gate_type ~= "" then
			push(
				"Gate Type",
				selected_visual.gate_type,
				{
					left_command = make_cycle_command("visual", selected_visual.id, "gate_type", -1),
					right_command = make_cycle_command("visual", selected_visual.id, "gate_type", 1),
					editable = true,
				}
			)
		end
		if selected_visual.delay_type ~= nil and selected_visual.delay_type ~= "" then
			push(
				"Delay Type",
				selected_visual.delay_type,
				{
					left_command = make_cycle_command("visual", selected_visual.id, "delay_type", -1),
					right_command = make_cycle_command("visual", selected_visual.id, "delay_type", 1),
					editable = true,
				}
			)
		end
		if selected_visual.scale_x ~= nil then
			push(
				"Scale X",
				string.format("%.1f", tonumber(selected_visual.scale_x) or 1),
				{
					left_command = make_adjust_command("visual", selected_visual.id, "scale_x", -0.5),
					right_command = make_adjust_command("visual", selected_visual.id, "scale_x", 0.5),
					editable = true,
				}
			)
		end
		if selected_visual.scale_y ~= nil then
			push(
				"Scale Y",
				string.format("%.1f", tonumber(selected_visual.scale_y) or 1),
				{
					left_command = make_adjust_command("visual", selected_visual.id, "scale_y", -0.5),
					right_command = make_adjust_command("visual", selected_visual.id, "scale_y", 0.5),
					editable = true,
				}
			)
		end
		return payload
	end

	local selected_connection = get_design_connection(self.design_diagram, self.selected_connection_id)
	if selected_connection ~= nil then
		payload.title = "Machinations [" .. selected_connection.id .. "]"
		push("Type", describe_connection_type(selected_connection))
		push("From", selected_connection.from or "-")
		push("To", selected_connection.to or "-")
		push("Label", describe_connection_label(selected_connection))
		if selected_connection.type == types.CONNECTION.STATE then
			push(
				"Action",
				selected_connection.action or types.STATE_ACTION.SET_ENABLED,
				{
					left_command = make_cycle_command("connection", selected_connection.id, "action", -1),
					right_command = make_cycle_command("connection", selected_connection.id, "action", 1),
					editable = true,
				}
			)
			push(
				"Source Field",
				selected_connection.source_field or types.STATE_FIELD.RESOURCES,
				{
					left_command = make_cycle_command("connection", selected_connection.id, "source_field", -1),
					right_command = make_cycle_command("connection", selected_connection.id, "source_field", 1),
					editable = true,
				}
			)
			push(
				"Comparator",
				selected_connection.comparator or types.COMPARATOR.GREATER,
				{
					left_command = make_cycle_command("connection", selected_connection.id, "comparator", -1),
					right_command = make_cycle_command("connection", selected_connection.id, "comparator", 1),
					editable = true,
				}
			)
			push(
				"Value",
				tonumber(selected_connection.value) or 0,
				{
					left_command = make_adjust_command("connection", selected_connection.id, "value", -1),
					right_command = make_adjust_command("connection", selected_connection.id, "value", 1),
					editable = true,
				}
			)
			push(
				"Scale",
				string.format("%.2f", tonumber(selected_connection.scale) or 1),
				{
					left_command = make_adjust_command("connection", selected_connection.id, "scale", -0.25),
					right_command = make_adjust_command("connection", selected_connection.id, "scale", 0.25),
					editable = true,
				}
			)
			push(
				"Use Delta",
				selected_connection.use_delta == true and "on" or "off",
				{
					click_command = make_toggle_command("connection", selected_connection.id, "use_delta"),
					editable = true,
				}
			)
			push(
				"Enabled",
				selected_connection.target_enabled == false and "off" or "on",
				{
					click_command = make_toggle_command("connection", selected_connection.id, "target_enabled"),
					editable = true,
				}
			)
			push(
				"Mode Op",
				selected_connection.register_op or "set",
				{
					left_command = make_cycle_command("connection", selected_connection.id, "register_op", -1),
					right_command = make_cycle_command("connection", selected_connection.id, "register_op", 1),
					editable = true,
				}
			)
			if selected_connection.target_trigger_mode ~= nil then
				push(
					"Target Mode",
					selected_connection.target_trigger_mode,
					{
						left_command = make_cycle_command("connection", selected_connection.id, "target_trigger_mode", -1),
						right_command = make_cycle_command("connection", selected_connection.id, "target_trigger_mode", 1),
						editable = true,
					}
				)
			end
		else
			push(
				"Flow",
				selected_connection.flow_mode or types.FLOW_MODE.PUSH,
				{
					left_command = make_cycle_command("connection", selected_connection.id, "flow_mode", -1),
					right_command = make_cycle_command("connection", selected_connection.id, "flow_mode", 1),
					editable = true,
				}
			)
			push(
				"Amount",
				tonumber(selected_connection.amount) or 1,
				{
					left_command = make_adjust_command("connection", selected_connection.id, "amount", -1),
					right_command = make_adjust_command("connection", selected_connection.id, "amount", 1),
					editable = true,
				}
			)
		end
		return payload
	end

	local selected_visual_connection = get_visual_connection(self.design_diagram, self.selected_connection_id)
	if selected_visual_connection ~= nil then
		payload.title = "Machinations [" .. selected_visual_connection.id .. "]"
		push("Type", describe_connection_type(selected_visual_connection))
		push("From", selected_visual_connection.from or "-")
		push("To", selected_visual_connection.to or "-")
		push("Label", describe_connection_label(selected_visual_connection))
		return payload
	end

	push("Name", self.design_diagram.name or "Machinations")
	push("Author", self.design_diagram.author or "-")
	local legacy_import = self.design_diagram.legacy_import
	push(
		"Time Mode",
		normalize_graph_time_mode(self.design_diagram),
		{
			left_command = make_cycle_command("graph", "-", "time_mode", -1),
			right_command = make_cycle_command("graph", "-", "time_mode", 1),
			editable = true,
		}
	)
	push(
		"Interval",
		string.format("%.1f", tonumber(self.design_diagram.interval) or 1),
		{
			left_command = make_adjust_command("graph", "-", "interval", -0.5),
			right_command = make_adjust_command("graph", "-", "interval", 0.5),
			editable = true,
		}
	)
	push(
		"Distribution",
		self.design_diagram.distribution_mode or "fixed speed",
		{
			left_command = make_cycle_command("graph", "-", "distribution_mode", -1),
			right_command = make_cycle_command("graph", "-", "distribution_mode", 1),
			editable = true,
		}
	)
	local color_coding = self.design_diagram.color_coding
	if color_coding == nil and type(legacy_import) == "table" then
		color_coding = legacy_import.color_coding == 1
	end
	push(
		"Color Coding",
		color_coding and "on" or "off",
		{
			click_command = make_toggle_command("graph", "-", "color_coding"),
			editable = true,
		}
	)
	push(
		"Dice",
		self.design_diagram.dice or "D6",
		{
			left_command = make_cycle_command("graph", "-", "dice", -1),
			right_command = make_cycle_command("graph", "-", "dice", 1),
			editable = true,
		}
	)
	push("Skill", self.design_diagram.skill or "")
	push("Multiplayer", self.design_diagram.multiplayer or "")
	push("Strategy", self.design_diagram.strategy or "")
	push(
		"Runs",
		self.number_of_runs or DEFAULT_NUMBER_OF_RUNS,
		{
			left_command = make_adjust_command("graph", "-", "number_of_runs", -10),
			right_command = make_adjust_command("graph", "-", "number_of_runs", 10),
			editable = true,
		}
	)
	push(
		"Visible Runs",
		self.visible_runs or DEFAULT_VISIBLE_RUNS,
		{
			left_command = make_adjust_command("graph", "-", "visible_runs", -5),
			right_command = make_adjust_command("graph", "-", "visible_runs", 5),
			editable = true,
		}
	)
	push(
		"Width",
		math.floor(tonumber(self.design_diagram.width) or 600),
		{
			left_command = make_adjust_command("graph", "-", "width", -40),
			right_command = make_adjust_command("graph", "-", "width", 40),
			editable = true,
		}
	)
	push(
		"Height",
		math.floor(tonumber(self.design_diagram.height) or 560),
		{
			left_command = make_adjust_command("graph", "-", "height", -40),
			right_command = make_adjust_command("graph", "-", "height", 40),
			editable = true,
		}
	)
	if type(legacy_import) == "table" then
		push("Legacy Ver", legacy_import.source_version or "-")
		push("Legacy Upg", legacy_import.upgraded_version or "-")
		push("Speed", legacy_import.speed or "-")
		push("Runs", legacy_import.number_of_runs or "-")
		push("Visible Runs", legacy_import.visible_runs or "-")
		push("Warnings", #(legacy_import.warnings or {}))
	end
	return payload
end

local function build_nodes_payload(self)
	local nodes = {}
	local selected_lookup = {}
	for _, node_id in ipairs(get_selected_node_ids(self)) do
		selected_lookup[node_id] = true
	end
	for _, node in ipairs(self.design_diagram.nodes or {}) do
		local pos = self.editor_positions[node.id] or { x = 0, y = 0 }
		local runtime_node = get_runtime_node(self, node.id)
		local display_node_type = node.type
		if type(node.data) == "table" and node.data.ap_functional == true then
			display_node_type = "artificial_player"
		end
		local width, height = get_payload_dimensions(display_node_type)
		local resources = node.initial_resources or 0
		local register_value = node.register_value or 0
		local enabled = node.enabled ~= false

		if runtime_node ~= nil then
			resources = runtime_node.resources
			register_value = runtime_node.register_value
			enabled = runtime_node.enabled
		end

		nodes[#nodes + 1] = {
			id = node.id,
			title = (node.data and node.data.legacy_caption) or node.id,
			icon = get_node_icon(display_node_type),
			shape = get_node_shape(display_node_type),
			node_type = display_node_type,
			x = pos.x,
			y = pos.y,
			resources = resources,
			register = register_value,
			width = width,
			height = height,
			value_text = get_node_value_text(node, runtime_node),
			enabled = enabled,
			selected = selected_lookup[node.id] == true,
			link_source = self.link_from_node_id == node.id,
		}
	end

	for _, visual_node in ipairs(self.design_diagram.legacy_visual_nodes or {}) do
		local caption = tostring(visual_node.caption or "")
		local title = caption ~= "" and caption or visual_node.symbol or visual_node.id
		local width, height = get_payload_dimensions(nil, visual_node)
		local x, y = resolve_visual_anchor_position(visual_node, width, height)
		nodes[#nodes + 1] = {
			id = visual_node.id,
			title = title,
			icon = get_node_icon("legacy_" .. string.lower(visual_node.symbol or "node")),
			shape = get_node_shape("legacy_" .. string.lower(visual_node.symbol or "node")),
			node_type = "legacy_" .. string.lower(visual_node.symbol or "node"),
			x = x,
			y = y,
			width = width,
			height = height,
			resources = 0,
			register = 0,
			value_text = get_legacy_visual_value(visual_node),
			enabled = true,
			selected = selected_lookup[visual_node.id] == true,
			link_source = false,
			visual_only = true,
			legacy_symbol = visual_node.symbol,
		}
	end
	return nodes
end

local function build_chart_payload(self)
	local payload = {
		node_id = nil,
		points = {},
		min = 0,
		max = 0,
	}
	if self.runtime_state == nil then
		if type(self.last_batch_chart_points) == "table" and #self.last_batch_chart_points >= 2 then
			payload.node_id = "batch_prediction"
			payload.points = copy_table(self.last_batch_chart_points)
			payload.min = payload.points[1] or 0
			payload.max = payload.points[#payload.points] or payload.min
		end
		return payload
	end

	local selected_ids = get_selected_node_ids(self)
	local focus_node_id = self.selected_node_id or selected_ids[1] or self.runtime_state.node_order[1]
	if focus_node_id ~= nil and self.runtime_state.nodes[focus_node_id] == nil then
		focus_node_id = self.runtime_state.node_order[1]
	end
	if focus_node_id == nil then
		return payload
	end
	payload.node_id = focus_node_id

	local node_history = self.runtime_state.metrics.node_history[focus_node_id]
	if node_history == nil then
		return payload
	end

	local source_points = node_history.resources or {}
	local start_index = math.max(#source_points - 5, 1)
	local min_value = nil
	local max_value = nil
	for index = start_index, #source_points do
		local value = tonumber(source_points[index]) or 0
		payload.points[#payload.points + 1] = value
		if min_value == nil or value < min_value then
			min_value = value
		end
		if max_value == nil or value > max_value then
			max_value = value
		end
	end

	payload.min = min_value or 0
	payload.max = max_value or 0
	if #payload.points < 2 and type(self.last_batch_chart_points) == "table" and #self.last_batch_chart_points >= 2 then
		payload.node_id = "batch_prediction"
		payload.points = copy_table(self.last_batch_chart_points)
		payload.min = payload.points[1] or 0
		payload.max = payload.points[#payload.points] or payload.min
	end
	return payload
end

local function build_edges_payload(self)
	local edges = {}
	local positions = build_position_lookup(self)
	for _, connection in ipairs(self.design_diagram.connections or {}) do
		local from_pos = positions[connection.from]
		local to_pos = positions[connection.to]
		if from_pos ~= nil and to_pos ~= nil then
			local points = build_edge_points(from_pos, to_pos, connection.data and connection.data.legacy_points or nil, connection.flow_mode)
			edges[#edges + 1] = {
				id = connection.id,
				connection_type = connection.type,
				flow_mode = connection.flow_mode or types.FLOW_MODE.PUSH,
				points = points,
				label = connection.data and connection.data.legacy_label or connection.amount_expression,
				selected = self.selected_connection_id == connection.id,
			}
		end
	end
	for _, connection in ipairs(self.design_diagram.legacy_visual_connections or {}) do
		local points = {}
		if connection.floating and type(connection.points) == "table" and #connection.points >= 2 then
			points = reverse_points(reverse_points(connection.points))
		else
			local from_pos = connection.from and positions[connection.from] or nil
			local to_pos = connection.to and positions[connection.to] or nil
			points = build_edge_points(from_pos, to_pos, connection.points, types.FLOW_MODE.PUSH)
		end
		if #points >= 2 then
			edges[#edges + 1] = {
				id = connection.id,
				connection_type = string.find(string.lower(tostring(connection.type or "")), "state", 1, true) and types.CONNECTION.STATE or types.CONNECTION.RESOURCE,
				flow_mode = types.FLOW_MODE.PUSH,
				points = points,
				label = connection.label,
				visual_only = true,
				selected = self.selected_connection_id == connection.id,
			}
		end
	end
	return edges
end

local function build_distribution_payload(self)
	if self.last_batch_distribution ~= nil then
		return copy_table(self.last_batch_distribution)
	end
	return {
		bins = {},
	}
end

local function build_accuracy_text(self)
	if type(self.last_accuracy_text) == "string" and self.last_accuracy_text ~= "" then
		return self.last_accuracy_text
	end
	return "Run batch to compute accuracy indicator."
end

local function build_diagram_library_payload(self)
	local items = {}
	for _, entry in ipairs(DIAGRAM_LIBRARY) do
		items[#items + 1] = {
			key = entry.key,
			label = entry.label,
			command = "load_diagram:" .. entry.key,
			selected = self.current_diagram_key == entry.key,
		}
	end
	return items
end

local function post_chunked_items(message_id, items, chunk_size)
	local total = #items
	if total == 0 then
		msg.post("#gui", message_id, {
			reset = true,
			done = true,
			items = {},
		})
		return
	end

	local index = 1
	while index <= total do
		local chunk_end = math.min(index + chunk_size - 1, total)
		local chunk = {}
		for item_index = index, chunk_end do
			chunk[#chunk + 1] = items[item_index]
		end

		msg.post("#gui", message_id, {
			reset = index == 1,
			done = chunk_end == total,
			items = chunk,
		})

		index = chunk_end + 1
	end
end

local function post_inspector_payload(payload)
	local fields = payload.fields or {}
	local total = #fields
	if total == 0 then
		msg.post("#gui", MSG_EDITOR_RENDER_INSPECTOR, {
			reset = true,
			done = true,
			title = payload.title or "Selection",
			status_line = payload.status_line or "",
			items = {},
		})
		return
	end

	local index = 1
	while index <= total do
		local chunk_end = math.min(index + INSPECTOR_CHUNK_SIZE - 1, total)
		local chunk = {}
		for item_index = index, chunk_end do
			chunk[#chunk + 1] = fields[item_index]
		end

		msg.post("#gui", MSG_EDITOR_RENDER_INSPECTOR, {
			reset = index == 1,
			done = chunk_end == total,
			title = payload.title or "Selection",
			status_line = payload.status_line or "",
			items = chunk,
		})

		index = chunk_end + 1
	end
end

local function send_render(self)
	if not self.render_dirty then
		return
	end

	local inspector_payload = build_inspector_payload(self)

	msg.post("#gui", MSG_EDITOR_RENDER_META, {
		camera_x = self.camera_x,
		camera_y = self.camera_y,
		camera_zoom = self.camera_zoom,
		hud = compose_hud_text(self),
		status = self.status_line or "",
		active_tool = self.active_tool or "select",
		autoplay = self.autoplay == true,
		active_diagram_key = self.current_diagram_key,
		number_of_runs = self.number_of_runs or DEFAULT_NUMBER_OF_RUNS,
		visible_runs = self.visible_runs or DEFAULT_VISIBLE_RUNS,
	})
	post_inspector_payload(inspector_payload)
	post_chunked_items(MSG_EDITOR_RENDER_LIBRARY, build_diagram_library_payload(self), LIBRARY_CHUNK_SIZE)

	post_chunked_items(MSG_EDITOR_RENDER_NODES, build_nodes_payload(self), NODE_CHUNK_SIZE)
	post_chunked_items(MSG_EDITOR_RENDER_EDGES, build_edges_payload(self), EDGE_CHUNK_SIZE)

	msg.post("#gui", MSG_EDITOR_RENDER_CHART, {
		chart = build_chart_payload(self),
	})

	msg.post("#gui", MSG_EDITOR_RENDER_BATCH, {
		distribution = build_distribution_payload(self),
		accuracy_text = build_accuracy_text(self),
	})

	self.render_dirty = false
end

local function step_runtime(self)
	if self.runtime_state == nil then
		self.status_line = "No runtime state to step."
		self.autoplay = false
		self.render_dirty = true
		return
	end

	local _, summary = Engine.step(self.runtime_state)
	self.last_step_summary = summary
	self.status_line = "Stepped simulation."
	if summary.ended then
		self.autoplay = false
		self.status_line = "Simulation ended: " .. tostring(summary.reason)
	end
	self.render_dirty = true
end

local function save_batch_report(report)
	local json_text, err = Io.encode_batch_report_json(report, true)
	if not json_text then
		return nil, err
	end

	local file, open_err = io.open(BATCH_REPORT_PATH, "wb")
	if not file then
		return nil, "open failed: " .. tostring(open_err)
	end

	local ok, write_err = file:write(json_text)
	file:close()
	if not ok then
		return nil, "write failed: " .. tostring(write_err)
	end

	return true
end

local function clear_analytics_state(self)
	self.last_batch_summary = ""
	self.last_batch_distribution = nil
	self.last_accuracy_text = nil
	self.last_batch_chart_points = nil
	self.last_autogen_report = nil
end

local function build_autogen_case_path(case_id)
	return string.format("source/diagrams/autogen_%s.json", tostring(case_id or "case"))
end

local function build_generated_case_distribution(diagram)
	local node_count = #(diagram.nodes or {})
	local resource_count = 0
	local state_count = 0

	for _, connection in ipairs(diagram.connections or {}) do
		if connection.type == types.CONNECTION.STATE then
			state_count = state_count + 1
		else
			resource_count = resource_count + 1
		end
	end

	return {
		bins = {
			{ label = "Nodes", count = node_count },
			{ label = "Res", count = resource_count },
			{ label = "State", count = state_count },
		},
	}
end

local function build_generated_case_chart_points(diagram)
	local node_count = #(diagram.nodes or {})
	local connection_count = #(diagram.connections or {})
	local max_ticks = tonumber((((diagram["end"] or {}).max_ticks))) or 0
	return {
		0,
		node_count,
		connection_count,
		max_ticks,
	}
end

local function build_generated_case_accuracy_text(case, index, total, diagram_path, save_err)
	local base = string.format(
		"Case %d/%d: %s\n%s",
		index,
		total,
		tostring(case.name or case.id or "Autogen"),
		tostring(case.description or "Auto-generated diagram")
	)
	if diagram_path == nil and save_err == nil then
		return base .. "\nBrowser preview only."
	end
	if save_err ~= nil then
		return base .. "\nSave failed: " .. tostring(save_err)
	end
	return base .. "\nSaved: " .. tostring(diagram_path)
end

local function find_first_failed_case(report)
	for _, case_result in ipairs(report.cases or {}) do
		if not case_result.ok then
			return case_result
		end
	end
	return nil
end

local function build_autogen_distribution(report)
	return {
		bins = {
			{ label = "Pass", count = report.passed or 0 },
			{ label = "Fail", count = report.failed or 0 },
		},
	}
end

local function build_autogen_chart_points(report)
	local points = {}
	for _, case_result in ipairs(report.cases or {}) do
		points[#points + 1] = tonumber(case_result.ticks or 0) or 0
	end
	if #points < 2 then
		points[#points + 1] = report.total or 0
	end
	return points
end

local function build_autogen_accuracy_text(report)
	local first_failure = find_first_failed_case(report)
	local report_suffix = tostring(report.report_path or AUTOGEN_REPORT_PATH)
	if report.failed == 0 then
		return string.format(
			"Generated %d cases.\nAll passed.\nReport: %s",
			report.total or 0,
			report_suffix
		)
	end
	return string.format(
		"Generated %d cases.\nFailed: %d.\nFirst failure: %s.\nReport: %s",
		report.total or 0,
		report.failed or 0,
		tostring(first_failure and (first_failure.id or first_failure.name or first_failure.message) or "unknown"),
		report_suffix
	)
end

local function run_batch_simulation(self, number_of_runs, visible_runs)
	local runs, visible = EditorActions.normalize_run_settings(
		number_of_runs or self.number_of_runs or DEFAULT_NUMBER_OF_RUNS,
		visible_runs or self.visible_runs or DEFAULT_VISIBLE_RUNS
	)
	self.number_of_runs = runs
	self.visible_runs = visible
	self.design_diagram.number_of_runs = runs
	self.design_diagram.visible_runs = visible

	local report, err = EditorActions.multiple_runs(self.design_diagram, {
		runs = runs,
		visible_runs = visible,
		max_ticks = 300,
		seed = self.seed,
	})
	if not report then
		self.status_line = "Batch failed: " .. tostring(err)
		self.render_dirty = true
		return
	end
	self.last_batch_distribution = nil
	self.last_accuracy_text = nil
	self.last_batch_chart_points = nil

	local top_reason = "-"
	local top_count = 0
	for reason, count in pairs(report.aggregates.end_reasons or {}) do
		if count > top_count then
			top_reason = reason
			top_count = count
		end
	end

	local mean_ticks = 0
	local ci_low = 0
	local ci_high = 0
	if report.aggregates ~= nil and report.aggregates.ticks ~= nil then
		mean_ticks = report.aggregates.ticks.mean or 0
		ci_low = report.aggregates.ticks.ci95_low or mean_ticks
		ci_high = report.aggregates.ticks.ci95_high or mean_ticks
	end

	local top_share = 0
	if report.aggregates ~= nil and report.aggregates.end_reason_share ~= nil then
		top_share = report.aggregates.end_reason_share[top_reason] or 0
	end

	self.last_batch_summary = string.format(
		"Batch runs=%d mean=%.1f ci=[%.1f..%.1f]",
		#report.runs,
		mean_ticks,
		ci_low,
		ci_high
	)

	local bins = {}
	local run_count = #report.runs
	if run_count > 0 then
		local min_tick = nil
		local max_tick = nil
		for _, run in ipairs(report.runs) do
			local ticks = tonumber(run.ticks) or 0
			if min_tick == nil or ticks < min_tick then
				min_tick = ticks
			end
			if max_tick == nil or ticks > max_tick then
				max_tick = ticks
			end
		end

		min_tick = min_tick or 0
		max_tick = max_tick or min_tick
		local bucket_count = math.min(10, math.max(4, math.floor(math.sqrt(run_count))))
		local span = math.max(max_tick - min_tick + 1, 1)
		local bucket_size = math.max(1, math.ceil(span / bucket_count))

		for bucket_index = 1, bucket_count do
			local start_tick = min_tick + (bucket_index - 1) * bucket_size
			local end_tick = math.min(start_tick + bucket_size - 1, max_tick)
			bins[bucket_index] = {
				label = string.format("%d-%d", start_tick, end_tick),
				count = 0,
			}
		end

		for _, run in ipairs(report.runs) do
			local ticks = tonumber(run.ticks) or 0
			local raw_index = math.floor((ticks - min_tick) / bucket_size) + 1
			local bucket_index = clamp(raw_index, 1, bucket_count)
			bins[bucket_index].count = (bins[bucket_index].count or 0) + 1
		end
	end

	self.last_batch_distribution = {
		bins = bins,
	}

	local sorted_ticks = {}
	for _, run in ipairs(report.runs) do
		sorted_ticks[#sorted_ticks + 1] = tonumber(run.ticks) or 0
	end
	table.sort(sorted_ticks)
	local min_tick_value = sorted_ticks[1] or 0
	local max_tick_value = sorted_ticks[#sorted_ticks] or 0
	local median_tick_value = mean_ticks
	if #sorted_ticks > 0 then
		local middle_index = math.floor((#sorted_ticks + 1) * 0.5)
		if #sorted_ticks % 2 == 0 then
			local left_value = sorted_ticks[math.max(middle_index, 1)] or 0
			local right_value = sorted_ticks[math.min(middle_index + 1, #sorted_ticks)] or left_value
			median_tick_value = (left_value + right_value) * 0.5
		else
			median_tick_value = sorted_ticks[middle_index] or mean_ticks
		end
	end
	local preview_points = {}
	local preview_count = math.min(#sorted_ticks, visible)
	if preview_count >= 2 then
		for preview_index = 1, preview_count do
			local t = (preview_index - 1) / (preview_count - 1)
			local source_index = math.floor(t * (#sorted_ticks - 1)) + 1
			preview_points[#preview_points + 1] = sorted_ticks[source_index]
		end
	end
	self.last_batch_chart_points = preview_points
	self.last_accuracy_text = string.format(
		"Most likely end: %s (%.1f%%).\nMean %.1f | Median %.1f | Min %d | Max %d.\n95%% CI [%.1f..%.1f].",
		tostring(top_reason),
		top_share * 100,
		mean_ticks,
		median_tick_value,
		math.floor(min_tick_value),
		math.floor(max_tick_value),
		ci_low,
		ci_high
	)

	local sys_info = sys.get_sys_info()
	local is_html5 = sys_info ~= nil and sys_info.system_name == "HTML5"
	if is_html5 then
		self.status_line = string.format("Multiple runs done in browser mode (%d runs).", runs)
	else
		local saved, save_err = save_batch_report(report)
		if not saved then
			self.status_line = "Multiple runs done, save failed: " .. tostring(save_err)
		else
			self.status_line = "Multiple runs done and report saved: " .. BATCH_REPORT_PATH
		end
	end

	self.render_dirty = true
end

local function run_regression_suite(self)
	local report = Regression.run_all()
	self.last_regression_report = report
	if report.failed > 0 then
		for _, case_result in ipairs(report.cases or {}) do
			if not case_result.ok then
				print(string.format(
					"machinations_regression: %s -> fail (%s)",
					case_result.name or "-",
					tostring(case_result.message or "")
				))
			end
		end
	end
	if report.failed == 0 then
		self.status_line = string.format("Regressions passed: %d/%d", report.passed, report.total)
	else
		local first_failure = nil
		for _, case_result in ipairs(report.cases or {}) do
			if not case_result.ok then
				first_failure = case_result
				break
			end
		end
		if first_failure ~= nil then
			self.status_line = string.format(
				"Regressions failed: %d/%d | %s: %s",
				report.failed,
				report.total,
				first_failure.name,
				first_failure.message
			)
		else
			self.status_line = string.format("Regressions failed: %d/%d", report.failed, report.total)
		end
	end
	self.render_dirty = true
end

local function load_autogenerated_case(self)
	local case, total, normalized_index = Autogen.get_case((self.autogen_case_index or 0) + 1, "default", self.seed)
	if case == nil then
		self.status_line = "Autogen did not return any cases."
		self.render_dirty = true
		return
	end

	local diagram_path = build_autogen_case_path(case.id)
	local browser_mode = is_html5_runtime()
	local saved = true
	local save_err = nil
	if not browser_mode then
		saved, save_err = Io.encode_diagram_file(diagram_path, case.diagram, true)
	end

	clear_analytics_state(self)
	apply_design_diagram(
		self,
		case.diagram,
		string.format("Auto-generated case %d/%d: %s", normalized_index, total, tostring(case.name or case.id)),
		true
	)
	self.current_diagram_key = nil

	self.autogen_case_index = normalized_index
	self.last_batch_distribution = build_generated_case_distribution(case.diagram)
	self.last_batch_chart_points = build_generated_case_chart_points(case.diagram)
	self.last_accuracy_text = build_generated_case_accuracy_text(
		case,
		normalized_index,
		total,
		diagram_path,
		saved == true and nil or save_err
	)
	if saved then
		if browser_mode then
			self.status_line = string.format("Auto-generated %s in browser mode", tostring(case.id))
		else
			self.status_line = string.format("Auto-generated %s and saved to %s", tostring(case.id), diagram_path)
		end
	else
		self.status_line = string.format("Auto-generated %s, save failed: %s", tostring(case.id), tostring(save_err))
	end
	self.render_dirty = true
end

local function run_auto_verification(self)
	clear_analytics_state(self)
	local browser_mode = is_html5_runtime()

	local report = Autogen.run_suite({
		profile = "default",
		seed = self.seed,
		persist = not browser_mode,
		diagram_dir = "source/diagrams",
		report_path = AUTOGEN_REPORT_PATH,
	})
	if browser_mode then
		report.report_path = "browser-memory"
	end

	self.last_autogen_report = report
	self.last_batch_distribution = build_autogen_distribution(report)
	self.last_batch_chart_points = build_autogen_chart_points(report)
	self.last_accuracy_text = build_autogen_accuracy_text(report)

	if report.failed > 0 then
		for _, case_result in ipairs(report.cases or {}) do
			if not case_result.ok then
				print(string.format(
					"machinations_autogen: %s -> fail (%s)",
					tostring(case_result.id or case_result.name or "-"),
					tostring(case_result.message or "")
				))
			end
		end
	end

	if report.failed == 0 then
		self.status_line = string.format("Auto verify passed: %d/%d", report.passed or 0, report.total or 0)
	else
		local first_failure = find_first_failed_case(report)
		self.status_line = string.format(
			"Auto verify failed: %d/%d | %s: %s",
			report.failed or 0,
			report.total or 0,
			tostring(first_failure and (first_failure.id or first_failure.name) or "unknown"),
			tostring(first_failure and first_failure.message or "")
		)
	end

	if report.report_saved == false then
		self.status_line = self.status_line .. " | save failed: " .. tostring(report.report_error)
	elseif browser_mode then
		self.status_line = self.status_line .. " | browser mode"
	else
		self.status_line = self.status_line .. " | " .. tostring(AUTOGEN_REPORT_PATH)
	end

	self.render_dirty = true
end

local function save_editor_snapshot(self)
	local diagram = copy_table(self.design_diagram)
	diagram.editor_positions = copy_table(self.editor_positions)
	local ok, err = Io.encode_diagram_file(SNAPSHOT_PATH, diagram, true)
	if not ok then
		self.status_line = "Save failed: " .. tostring(err)
	else
		self.status_line = "Saved diagram snapshot: " .. SNAPSHOT_PATH
	end
	self.render_dirty = true
end

local function export_selection_snapshot(self)
	local selected_ids = get_selected_node_ids(self)
	if #selected_ids == 0 then
		self.status_line = "Export selection failed: no selected nodes."
		self.render_dirty = true
		return
	end

	local selection = EditorActions.export_selection(self.design_diagram, self.editor_positions, selected_ids)
	local ok, err = Io.encode_diagram_file(SELECTION_EXPORT_PATH, selection, true)
	if not ok then
		self.status_line = "Export selection failed: " .. tostring(err)
	else
		self.status_line = "Selection exported: " .. SELECTION_EXPORT_PATH
	end
	self.render_dirty = true
end

local function save_diagram_svg(self)
	local svg_text = EditorActions.build_svg(self.design_diagram, self.editor_positions, {
		width = self.design_diagram.width,
		height = self.design_diagram.height,
	})
	local ok, err = write_text_file(SVG_EXPORT_PATH, svg_text)
	if not ok then
		self.status_line = "SVG export failed: " .. tostring(err)
	else
		self.status_line = "SVG exported: " .. SVG_EXPORT_PATH
	end
	self.render_dirty = true
end

local function run_quick_simulation(self)
	clear_analytics_state(self)
	local report, err = EditorActions.quick_run(self.design_diagram, {
		seed = self.seed,
		max_ticks = 300,
	})
	if not report then
		self.status_line = "Quick run failed: " .. tostring(err)
		self.render_dirty = true
		return
	end

	self.runtime_state = report.state
	self.autoplay = false
	self.autoplay_accum = 0
	if report.ended then
		self.status_line = string.format(
			"Quick run ended at tick %d (%s).",
			math.floor(tonumber(report.ticks) or 0),
			tostring(report.end_reason or "ended")
		)
	else
		self.status_line = string.format(
			"Quick run reached tick %d without end condition.",
			math.floor(tonumber(report.ticks) or 0)
		)
	end
	self.render_dirty = true
end

local function select_all_nodes(self)
	local selected_ids = EditorActions.select_all(self.design_diagram)
	if #selected_ids == 0 then
		self.status_line = "Select all: no nodes in diagram."
	else
		set_selected_nodes(self, selected_ids, selected_ids[1])
		self.status_line = string.format("Selected %d nodes.", #selected_ids)
	end
	self.render_dirty = true
end

local function copy_selected_nodes(self)
	local selected_ids = get_selected_node_ids(self)
	self.clipboard = EditorActions.copy_selection(self.design_diagram, self.editor_positions, selected_ids)
	self.paste_shift = 0
	if self.clipboard == nil then
		self.status_line = "Copy failed: no selected nodes."
	else
		self.status_line = string.format("Copied %d nodes.", #(self.clipboard.selected_ids or {}))
	end
	self.render_dirty = true
end

local function paste_selected_nodes(self)
	if self.clipboard == nil then
		self.status_line = "Paste failed: clipboard is empty."
		self.render_dirty = true
		return
	end

	self.paste_shift = (self.paste_shift or 0) + 20
	local diagram, positions, pasted_ids = EditorActions.paste_selection(
		self.design_diagram,
		self.editor_positions,
		self.clipboard,
		{
			offset_x = self.paste_shift,
			offset_y = self.paste_shift,
		}
	)
	self.design_diagram = diagram
	self.editor_positions = positions
	set_selected_nodes(self, pasted_ids, pasted_ids[1])
	setup_serials(self)
	restart_runtime(self)
	push_history_state(self)
	self.status_line = string.format("Pasted %d nodes.", #pasted_ids)
	self.render_dirty = true
end

local function undo_editor_change(self)
	local snapshot = nil
	self.history, snapshot = EditorActions.undo_history(self.history or EditorActions.new_history(capture_history_snapshot(self), HISTORY_LIMIT))
	if snapshot == nil then
		self.status_line = "Undo unavailable."
		self.render_dirty = true
		return
	end
	restore_history_snapshot(self, snapshot, "Undo.")
end

local function redo_editor_change(self)
	local snapshot = nil
	self.history, snapshot = EditorActions.redo_history(self.history or EditorActions.new_history(capture_history_snapshot(self), HISTORY_LIMIT))
	if snapshot == nil then
		self.status_line = "Redo unavailable."
		self.render_dirty = true
		return
	end
	restore_history_snapshot(self, snapshot, "Redo.")
end

local function fit_camera_to_diagram(self)
	local min_x = nil
	local max_x = nil
	local min_y = nil
	local max_y = nil

	local function include_bounds(center_x, center_y, width, height)
		local half_w = width * 0.5
		local half_h = height * 0.5
		local left = center_x - half_w
		local right = center_x + half_w
		local bottom = center_y - half_h
		local top = center_y + half_h
		min_x = min_x == nil and left or math.min(min_x, left)
		max_x = max_x == nil and right or math.max(max_x, right)
		min_y = min_y == nil and bottom or math.min(min_y, bottom)
		max_y = max_y == nil and top or math.max(max_y, top)
	end

	for _, node in ipairs(self.design_diagram.nodes or {}) do
		local pos = self.editor_positions[node.id]
		if pos ~= nil then
			local node_type = node.type
			if type(node.data) == "table" and node.data.ap_functional == true then
				node_type = "artificial_player"
			end
			local width, height = get_payload_dimensions(node_type)
			include_bounds(pos.x, pos.y, width, height)
		end
	end

	for _, visual_node in ipairs(self.design_diagram.legacy_visual_nodes or {}) do
		local width, height = get_payload_dimensions(nil, visual_node)
		local center_x, center_y = resolve_visual_anchor_position(visual_node, width, height)
		include_bounds(center_x, center_y, width, height)
	end

	if min_x == nil or max_x == nil or min_y == nil or max_y == nil then
		self.camera_x = 0
		self.camera_y = 0
		self.camera_zoom = 0.9
		return
	end

	local viewport_w = self.viewport_w or DEFAULT_VIEWPORT_W
	local viewport_h = self.viewport_h or DEFAULT_VIEWPORT_H
	local left, right, bottom, top = get_canvas_rect(viewport_w, viewport_h)
	local canvas_w = math.max((right - left) - 48, 80)
	local canvas_h = math.max((top - bottom) - 48, 80)
	local world_w = math.max((max_x - min_x) + 160, 120)
	local world_h = math.max((max_y - min_y) + 160, 120)

	self.camera_x = (min_x + max_x) * 0.5
	self.camera_y = (min_y + max_y) * 0.5
	self.camera_zoom = clamp(math.min(canvas_w / world_w, canvas_h / world_h), 0.35, 1.1)
end

restore_history_snapshot = function(self, snapshot, status_line)
	if snapshot == nil then
		return false
	end

	self.design_diagram = copy_table(snapshot.diagram or {})
	self.editor_positions = copy_table(snapshot.positions or {})
	apply_auto_positions(self.design_diagram, self.editor_positions)
	sync_run_settings(self)
	self.dragging_node_id = nil
	self.drag_node_moved = false
	self.panning = false
	self.autoplay = false
	self.autoplay_accum = 0
	self.link_from_node_id = nil
	self.selected_connection_id = nil

	if type(snapshot.camera) == "table" then
		self.camera_x = tonumber(snapshot.camera.x) or 0
		self.camera_y = tonumber(snapshot.camera.y) or 0
		self.camera_zoom = clamp(tonumber(snapshot.camera.zoom) or 0.9, 0.2, 4.0)
	else
		fit_camera_to_diagram(self)
	end

	setup_serials(self)
	restart_runtime(self)
	set_selected_nodes(self, snapshot.selected_ids or {}, snapshot.primary_selected_id)
	self.selected_connection_id = snapshot.selected_connection_id
	self.status_line = status_line or "History restored."
	self.render_dirty = true
	return true
end

function apply_design_diagram(self, diagram, status_line, overwrite_initial)
	self.design_diagram = copy_table(diagram)
	self.editor_positions = extract_editor_positions(self.design_diagram)
	apply_auto_positions(self.design_diagram, self.editor_positions)
	set_selected_nodes(self, {}, nil)
	self.selected_connection_id = nil
	self.dragging_node_id = nil
	self.drag_node_moved = false
	self.panning = false
	self.autoplay = false
	self.autoplay_accum = 0
	self.link_from_node_id = nil
	sync_run_settings(self)
	fit_camera_to_diagram(self)
	setup_serials(self)
	restart_runtime(self)

	if overwrite_initial then
		self.initial_diagram = copy_table(self.design_diagram)
	end

	self.status_line = status_line
	reset_history(self)
	self.render_dirty = true
end

local function load_design_diagram(self, path)
	local diagram, err = load_diagram_from_path(path)
	if not diagram then
		self.status_line = "Load failed: " .. tostring(err)
		print("machinations_load_failed", path, tostring(err))
		self.render_dirty = true
		return false
	end

	local status_line = "Loaded diagram: " .. path
	local legacy_import = diagram.legacy_import
	if type(legacy_import) == "table" then
		status_line = string.format(
			"Imported legacy XML: %s (warnings %d)",
			path,
			#(legacy_import.warnings or {})
		)
	end

	apply_design_diagram(self, diagram, status_line, true)
	self.current_diagram_key = detect_library_key_from_path(path)
	return true
end

local function load_named_diagram(self, diagram_key)
	local entry = get_library_entry(diagram_key)
	if entry == nil then
		self.status_line = "Unknown diagram: " .. tostring(diagram_key)
		self.render_dirty = true
		return false
	end
	local loaded = load_design_diagram(self, entry.path)
	if loaded then
		self.current_diagram_key = entry.key
	end
	return loaded
end

local function reset_design_diagram(self)
	if self.initial_diagram == nil then
		return
	end
	apply_design_diagram(self, self.initial_diagram, "Reset to initial diagram.", false)
end

local function make_unique_node_id(self, prefix)
	while true do
		local id = prefix .. "_" .. tostring(self.next_node_serial)
		self.next_node_serial = self.next_node_serial + 1
		if not node_id_exists(self.design_diagram, id) then
			return id
		end
	end
end

local function make_unique_connection_id(self, prefix)
	while true do
		local id = prefix .. "_" .. tostring(self.next_connection_serial)
		self.next_connection_serial = self.next_connection_serial + 1
		if not connection_id_exists(self.design_diagram, id) then
			return id
		end
	end
end

local function add_connection(self, from_id, to_id, connection_type, options)
	if from_id == nil or to_id == nil or from_id == to_id then
		return false
	end

	local added = EditorActions.append_connection(
		self.design_diagram,
		from_id,
		to_id,
		connection_type or types.CONNECTION.RESOURCE,
		options
	)
	setup_serials(self)
	return added
end

local function add_visual_node(self, symbol, world_x, world_y)
	local visual_id = make_unique_node_id(self, string.lower(symbol or "visual"))
	local visual_node = {
		id = visual_id,
		symbol = symbol,
		caption = visual_id,
		x = world_x or self.camera_x,
		y = world_y or self.camera_y,
		width = 132,
		height = 72,
		color = "Black",
	}

	if symbol == "TextLabel" then
		visual_node.caption = "Text Label"
		visual_node.width = 128
		visual_node.height = 28
	elseif symbol == "GroupBox" then
		visual_node.caption = "Group"
		visual_node.width = 220
		visual_node.height = 120
		set_visual_anchor_position(visual_node, world_x or self.camera_x, world_y or self.camera_y)
	elseif symbol == "Chart" then
		visual_node.caption = "Chart"
		visual_node.width = 220
		visual_node.height = 120
		visual_node.scale_x = 1
		visual_node.scale_y = 1
		set_visual_anchor_position(visual_node, world_x or self.camera_x, world_y or self.camera_y)
	elseif symbol == "ArtificialPlayer" then
		visual_node.caption = "Artificial Player"
		visual_node.width = 90
		visual_node.height = 56
		visual_node.actions_per_turn = 1
	end

	self.design_diagram.legacy_visual_nodes = self.design_diagram.legacy_visual_nodes or {}
	table.insert(self.design_diagram.legacy_visual_nodes, visual_node)
	select_single_node(self, visual_id)
	push_history_state(self)
	self.status_line = "Added visual node: " .. visual_id
	self.render_dirty = true
end

local function add_node(self, node_type, world_x, world_y)
	local prefix = node_type == "artificial_player" and "ap" or node_type
	local node_id = make_unique_node_id(self, prefix)
	local node = {
		id = node_id,
		type = node_type == "artificial_player" and types.NODE.REGISTER or node_type,
		trigger_mode = types.TRIGGER_MODE.AUTOMATIC,
		initial_resources = 0,
		rate = 1,
		register_value = 0,
		enabled = true,
		data = {},
	}

	if node_type == types.NODE.SOURCE then
		node.initial_resources = 20
		node.data.finite_source = true
	elseif node_type == types.NODE.DRAIN then
		node.trigger_mode = types.TRIGGER_MODE.PASSIVE
	elseif node_type == types.NODE.CONVERTER or node_type == types.NODE.TRADER then
		node.trigger_mode = types.TRIGGER_MODE.PASSIVE
	elseif node_type == types.NODE.REGISTER then
		node.trigger_mode = types.TRIGGER_MODE.PASSIVE
	elseif node_type == types.NODE.GATE then
		node.gate_mode = types.GATE_MODE.ALL
	elseif node_type == types.NODE.QUEUE or node_type == types.NODE.DELAY then
		node.delay_ticks = 1
	elseif node_type == types.NODE.END_CONDITION then
		node.trigger_mode = types.TRIGGER_MODE.PASSIVE
		node.enabled = false
	elseif node_type == "artificial_player" then
		node.trigger_mode = types.TRIGGER_MODE.AUTOMATIC
		node.actions_per_turn = 1
		node.script = ""
		node.data.legacy_caption = "Artificial Player"
		node.data.ap_script_preset = "blank"
		node.data.ap_functional = true
	end

	table.insert(self.design_diagram.nodes, node)
	self.editor_positions[node_id] = {
		x = world_x or self.camera_x,
		y = world_y or self.camera_y,
	}

	if self.selected_node_id ~= nil and get_design_node(self.design_diagram, self.selected_node_id) ~= nil then
		add_connection(self, self.selected_node_id, node_id)
	end

	select_single_node(self, node_id)
	restart_runtime(self)
	push_history_state(self)
	self.status_line = "Added node: " .. node_id
	self.render_dirty = true
end

local function delete_selected_node(self)
	if self.selected_connection_id ~= nil then
		local removed = false
		for index = #(self.design_diagram.connections or {}), 1, -1 do
			if self.design_diagram.connections[index].id == self.selected_connection_id then
				table.remove(self.design_diagram.connections, index)
				removed = true
				break
			end
		end
		if not removed then
			for index = #(self.design_diagram.legacy_visual_connections or {}), 1, -1 do
				if self.design_diagram.legacy_visual_connections[index].id == self.selected_connection_id then
					table.remove(self.design_diagram.legacy_visual_connections, index)
					removed = true
					break
				end
			end
		end
		if removed then
			self.selected_connection_id = nil
			restart_runtime(self)
			push_history_state(self)
			self.status_line = "Deleted connection."
		else
			self.status_line = "Selected connection not found."
		end
		self.render_dirty = true
		return
	end

	local selected_ids = get_selected_node_ids(self)
	if #selected_ids == 0 then
		self.status_line = "No selected node."
		self.render_dirty = true
		return
	end

	for _, node_id in ipairs(selected_ids) do
		local index = find_node_index(self.design_diagram, node_id)
		if index ~= nil then
			table.remove(self.design_diagram.nodes, index)
			remove_connections_for_node(self.design_diagram, node_id)
			self.editor_positions[node_id] = nil
		else
			local visual_index = find_visual_node_index(self.design_diagram, node_id)
			if visual_index ~= nil then
				table.remove(self.design_diagram.legacy_visual_nodes, visual_index)
				remove_connections_for_node(self.design_diagram, node_id)
			end
		end
	end
	set_selected_nodes(self, {}, nil)
	restart_runtime(self)
	push_history_state(self)
	self.status_line = string.format("Deleted %d node(s).", #selected_ids)
	self.render_dirty = true
end

local GRAPH_TIME_MODES = { "asynchronous", "synchronous", "turn_based" }
local DISTRIBUTION_MODES = { "fixed speed", "instantaneous" }
local DICE_OPTIONS = { "D4", "D6", "D8", "D10", "D12", "D20" }
local ACTIVATION_OPTIONS = { "passive", "interactive", "automatic", "onStart" }
local PULL_MODE_OPTIONS = { "pull_any", "pull_all", "push_any", "push_all" }
local GATE_TYPE_OPTIONS = { "deterministic", "dice", "skill", "multiplayer", "strategy" }
local DELAY_TYPE_OPTIONS = { "delay", "queue" }
local RESOURCE_COLOR_OPTIONS = { "Black", "White", "Red", "Blue", "Green", "Yellow", "Purple", "Orange" }
local CONNECTION_ACTION_OPTIONS = {
	types.STATE_ACTION.SET_ENABLED,
	types.STATE_ACTION.TOGGLE_ENABLED,
	types.STATE_ACTION.SET_TRIGGER_MODE,
	types.STATE_ACTION.SET_REGISTER,
	types.STATE_ACTION.SET_VARIABLE,
	types.STATE_ACTION.SCALE_VARIABLE,
	types.STATE_ACTION.SET_RATE,
	types.STATE_ACTION.SET_CAPACITY,
	types.STATE_ACTION.ADD_RESOURCE,
}
local CONNECTION_FIELD_OPTIONS = {
	types.STATE_FIELD.RESOURCES,
	types.STATE_FIELD.REGISTER,
	types.STATE_FIELD.INCOMING,
	types.STATE_FIELD.OUTGOING,
	types.STATE_FIELD.TICK,
}
local CONNECTION_COMPARATOR_OPTIONS = {
	types.COMPARATOR.GREATER,
	types.COMPARATOR.GREATER_OR_EQUAL,
	types.COMPARATOR.LESS,
	types.COMPARATOR.LESS_OR_EQUAL,
	types.COMPARATOR.EQUAL,
	types.COMPARATOR.NOT_EQUAL,
}
local CONNECTION_REGISTER_OP_OPTIONS = { "set", "add", "mul" }
local CONNECTION_TRIGGER_OPTIONS = {
	types.TRIGGER_MODE.PASSIVE,
	types.TRIGGER_MODE.INTERACTIVE,
	types.TRIGGER_MODE.AUTOMATIC,
	types.TRIGGER_MODE.ENABLING,
}
local FLOW_MODE_OPTIONS = { types.FLOW_MODE.PUSH, types.FLOW_MODE.PULL }

local function split_command(command)
	local parts = {}
	for part in string.gmatch(command or "", "([^:]+)") do
		parts[#parts + 1] = part
	end
	return parts
end

local function clamp_number(value, min_value, max_value)
	value = tonumber(value) or min_value
	if min_value ~= nil then
		value = math.max(value, min_value)
	end
	if max_value ~= nil then
		value = math.min(value, max_value)
	end
	return value
end

local function apply_graph_cycle(self, key, direction)
	if key == "time_mode" then
		local next_mode = cycle_value(normalize_graph_time_mode(self.design_diagram), GRAPH_TIME_MODES, direction)
		self.design_diagram.time_mode = next_mode
		if next_mode == "turn_based" then
			self.design_diagram.play_mode = types.PLAY_MODE.INTERACTIVE
		else
			self.design_diagram.play_mode = types.PLAY_MODE.HEADLESS
		end
		return true, "Time mode: " .. next_mode
	end
	if key == "distribution_mode" then
		local next_mode = cycle_value(self.design_diagram.distribution_mode or DISTRIBUTION_MODES[1], DISTRIBUTION_MODES, direction)
		self.design_diagram.distribution_mode = next_mode
		return true, "Distribution: " .. next_mode
	end
	if key == "dice" then
		local next_value = cycle_value(self.design_diagram.dice or DICE_OPTIONS[2], DICE_OPTIONS, direction)
		self.design_diagram.dice = next_value
		return true, "Dice: " .. next_value
	end
	return false
end

local function apply_graph_adjust(self, key, delta)
	if key == "interval" then
		self.design_diagram.interval = clamp_number((tonumber(self.design_diagram.interval) or 1) + delta, 0.1, 20)
		return true, string.format("Interval %.1f", tonumber(self.design_diagram.interval) or 1)
	end
	if key == "width" then
		self.design_diagram.width = math.floor(clamp_number((tonumber(self.design_diagram.width) or 600) + delta, 160, 2400))
		fit_camera_to_diagram(self)
		return true, "Width " .. tostring(self.design_diagram.width)
	end
	if key == "height" then
		self.design_diagram.height = math.floor(clamp_number((tonumber(self.design_diagram.height) or 560) + delta, 160, 2400))
		fit_camera_to_diagram(self)
		return true, "Height " .. tostring(self.design_diagram.height)
	end
	if key == "number_of_runs" then
		local runs, visible = EditorActions.normalize_run_settings((self.number_of_runs or DEFAULT_NUMBER_OF_RUNS) + delta, self.visible_runs or DEFAULT_VISIBLE_RUNS)
		self.number_of_runs = runs
		self.visible_runs = visible
		self.design_diagram.number_of_runs = runs
		self.design_diagram.visible_runs = visible
		return true, "Runs " .. tostring(runs)
	end
	if key == "visible_runs" then
		local runs, visible = EditorActions.normalize_run_settings(self.number_of_runs or DEFAULT_NUMBER_OF_RUNS, (self.visible_runs or DEFAULT_VISIBLE_RUNS) + delta)
		self.number_of_runs = runs
		self.visible_runs = visible
		self.design_diagram.number_of_runs = runs
		self.design_diagram.visible_runs = visible
		return true, "Visible runs " .. tostring(visible)
	end
	return false
end

local function apply_graph_toggle(self, key)
	if key == "color_coding" then
		self.design_diagram.color_coding = not (self.design_diagram.color_coding == true)
		return true, "Color coding: " .. (self.design_diagram.color_coding and "on" or "off")
	end
	return false
end

local function apply_node_cycle(node, key, direction)
	node.data = node.data or {}
	if key == "trigger_mode" then
		local current_value = node.data.legacy_activation_mode or node.trigger_mode or ACTIVATION_OPTIONS[1]
		local next_value = cycle_value(current_value, ACTIVATION_OPTIONS, direction)
		node.data.legacy_activation_mode = next_value
		if next_value == "passive" then
			node.trigger_mode = types.TRIGGER_MODE.PASSIVE
		elseif next_value == "interactive" then
			node.trigger_mode = types.TRIGGER_MODE.INTERACTIVE
		elseif next_value == "onStart" then
			node.trigger_mode = types.TRIGGER_MODE.AUTOMATIC
		else
			node.trigger_mode = types.TRIGGER_MODE.AUTOMATIC
		end
		return true, "Activation: " .. next_value
	end
	if key == "pull_mode" then
		node.data.legacy_pull_mode = cycle_value(node.data.legacy_pull_mode or PULL_MODE_OPTIONS[1], PULL_MODE_OPTIONS, direction)
		return true, "Pull mode: " .. tostring(node.data.legacy_pull_mode)
	end
	if key == "gate_type" then
		node.data.legacy_gate_type = cycle_value(node.data.legacy_gate_type or GATE_TYPE_OPTIONS[1], GATE_TYPE_OPTIONS, direction)
		if node.data.legacy_gate_type == "deterministic" then
			node.gate_mode = types.GATE_MODE.ROUND_ROBIN
		else
			node.gate_mode = types.GATE_MODE.RANDOM
		end
		return true, "Gate type: " .. tostring(node.data.legacy_gate_type)
	end
	if key == "delay_type" then
		local next_type = cycle_value(node.data.legacy_delay_type or DELAY_TYPE_OPTIONS[1], DELAY_TYPE_OPTIONS, direction)
		node.data.legacy_delay_type = next_type
		node.type = next_type == "queue" and types.NODE.QUEUE or types.NODE.DELAY
		return true, "Delay type: " .. next_type
	end
	if key == "resource_color" then
		node.data.legacy_resource_color = cycle_value(node.data.legacy_resource_color or RESOURCE_COLOR_OPTIONS[1], RESOURCE_COLOR_OPTIONS, direction)
		return true, "Resource color: " .. tostring(node.data.legacy_resource_color)
	end
	if key == "script" then
		return set_ap_script_preset(node, direction)
	end
	return false
end

local function apply_node_adjust(node, key, delta)
	node.data = node.data or {}
	if key == "rate" then
		node.rate = math.floor(clamp_number((tonumber(node.rate) or 1) + delta, 1, 999))
		return true, "Rate: " .. tostring(node.rate)
	end
	if key == "capacity" then
		node.capacity = math.floor((tonumber(node.capacity) or -1) + delta)
		if node.capacity < -1 then
			node.capacity = -1
		end
		return true, "Capacity: " .. tostring(node.capacity)
	end
	if key == "initial_resources" then
		node.initial_resources = math.floor(clamp_number((tonumber(node.initial_resources) or 0) + delta, 0, 9999))
		return true, "Resources: " .. tostring(node.initial_resources)
	end
	if key == "register_value" then
		node.register_value = math.floor((tonumber(node.register_value) or 0) + delta)
		return true, "Register: " .. tostring(node.register_value)
	end
	if key == "legacy_actions" then
		node.data.legacy_actions = math.floor(clamp_number((tonumber(node.data.legacy_actions) or 0) + delta, 0, 999))
		return true, "Actions: " .. tostring(node.data.legacy_actions)
	end
	if key == "actions_per_turn" then
		node.actions_per_turn = math.floor(clamp_number((tonumber(node.actions_per_turn) or 1) + delta, 1, 999))
		return true, "Actions/turn: " .. tostring(node.actions_per_turn)
	end
	if key == "display_capacity" then
		node.data.legacy_display_capacity = math.floor(clamp_number((tonumber(node.data.legacy_display_capacity) or 0) + delta, 0, 9999))
		return true, "Display cap: " .. tostring(node.data.legacy_display_capacity)
	end
	if key == "legacy_min" then
		node.data.legacy_min = math.floor((tonumber(node.data.legacy_min) or 0) + delta)
		return true, "Min: " .. tostring(node.data.legacy_min)
	end
	if key == "legacy_max" then
		node.data.legacy_max = math.floor((tonumber(node.data.legacy_max) or 0) + delta)
		return true, "Max: " .. tostring(node.data.legacy_max)
	end
	if key == "legacy_step" then
		node.data.legacy_step = math.floor(clamp_number((tonumber(node.data.legacy_step) or 1) + delta, 1, 99))
		return true, "Step: " .. tostring(node.data.legacy_step)
	end
	return false
end

local function apply_visual_cycle(visual_node, key, direction)
	if key == "gate_type" then
		visual_node.gate_type = cycle_value(visual_node.gate_type or GATE_TYPE_OPTIONS[1], GATE_TYPE_OPTIONS, direction)
		return true, "Gate type: " .. tostring(visual_node.gate_type)
	end
	if key == "delay_type" then
		visual_node.delay_type = cycle_value(visual_node.delay_type or DELAY_TYPE_OPTIONS[1], DELAY_TYPE_OPTIONS, direction)
		return true, "Delay type: " .. tostring(visual_node.delay_type)
	end
	return false
end

local function apply_visual_adjust(visual_node, key, delta)
	if key == "width" then
		visual_node.width = math.floor(clamp_number((tonumber(visual_node.width) or 120) + delta, 48, 2400))
		return true, "Width: " .. tostring(visual_node.width)
	end
	if key == "height" then
		visual_node.height = math.floor(clamp_number((tonumber(visual_node.height) or 60) + delta, 28, 1800))
		return true, "Height: " .. tostring(visual_node.height)
	end
	if key == "actions_per_turn" then
		visual_node.actions_per_turn = math.floor(clamp_number((tonumber(visual_node.actions_per_turn) or 1) + delta, 1, 999))
		return true, "Actions/turn: " .. tostring(visual_node.actions_per_turn)
	end
	if key == "scale_x" then
		visual_node.scale_x = clamp_number((tonumber(visual_node.scale_x) or 1) + delta, 0.5, 20)
		return true, string.format("Scale X %.1f", tonumber(visual_node.scale_x) or 1)
	end
	if key == "scale_y" then
		visual_node.scale_y = clamp_number((tonumber(visual_node.scale_y) or 1) + delta, 0.5, 20)
		return true, string.format("Scale Y %.1f", tonumber(visual_node.scale_y) or 1)
	end
	return false
end

local function apply_connection_cycle(connection, key, direction)
	if connection.type == types.CONNECTION.STATE then
		if key == "action" then
			connection.action = cycle_value(connection.action or CONNECTION_ACTION_OPTIONS[1], CONNECTION_ACTION_OPTIONS, direction)
			return true, "Action: " .. tostring(connection.action)
		end
		if key == "source_field" then
			connection.source_field = cycle_value(connection.source_field or CONNECTION_FIELD_OPTIONS[1], CONNECTION_FIELD_OPTIONS, direction)
			return true, "Field: " .. tostring(connection.source_field)
		end
		if key == "comparator" then
			connection.comparator = cycle_value(connection.comparator or CONNECTION_COMPARATOR_OPTIONS[1], CONNECTION_COMPARATOR_OPTIONS, direction)
			return true, "Comparator: " .. tostring(connection.comparator)
		end
		if key == "register_op" then
			connection.register_op = cycle_value(connection.register_op or CONNECTION_REGISTER_OP_OPTIONS[1], CONNECTION_REGISTER_OP_OPTIONS, direction)
			return true, "Mode op: " .. tostring(connection.register_op)
		end
		if key == "target_trigger_mode" then
			connection.target_trigger_mode = cycle_value(connection.target_trigger_mode or CONNECTION_TRIGGER_OPTIONS[1], CONNECTION_TRIGGER_OPTIONS, direction)
			return true, "Target mode: " .. tostring(connection.target_trigger_mode)
		end
	elseif key == "flow_mode" then
		connection.flow_mode = cycle_value(connection.flow_mode or FLOW_MODE_OPTIONS[1], FLOW_MODE_OPTIONS, direction)
		return true, "Flow: " .. tostring(connection.flow_mode)
	end
	return false
end

local function apply_connection_adjust(connection, key, delta)
	if key == "amount" then
		connection.amount = math.floor(clamp_number((tonumber(connection.amount) or 1) + delta, 1, 9999))
		return true, "Amount: " .. tostring(connection.amount)
	end
	if key == "value" then
		connection.value = (tonumber(connection.value) or 0) + delta
		return true, "Value: " .. tostring(connection.value)
	end
	if key == "scale" then
		connection.scale = clamp_number((tonumber(connection.scale) or 1) + delta, 0, 999)
		return true, string.format("Scale %.2f", tonumber(connection.scale) or 1)
	end
	return false
end

local function apply_connection_toggle(connection, key)
	if key == "use_delta" then
		connection.use_delta = not (connection.use_delta == true)
		return true, "Use delta: " .. (connection.use_delta and "on" or "off")
	end
	if key == "target_enabled" then
		connection.target_enabled = connection.target_enabled == false
		return true, "Enabled: " .. (connection.target_enabled and "on" or "off")
	end
	return false
end

local function mutate_property(self, operation, scope, target_id, key, raw_value)
	local diagram_changed = false
	local status_line = nil

	if scope == "graph" then
		if operation == "cycle" then
			diagram_changed, status_line = apply_graph_cycle(self, key, tonumber(raw_value) or 1)
		elseif operation == "adjust" then
			diagram_changed, status_line = apply_graph_adjust(self, key, tonumber(raw_value) or 0)
		elseif operation == "toggle" then
			diagram_changed, status_line = apply_graph_toggle(self, key)
		end
	elseif scope == "node" then
		local node = get_design_node(self.design_diagram, target_id)
		if node ~= nil then
			if operation == "cycle" then
				diagram_changed, status_line = apply_node_cycle(node, key, tonumber(raw_value) or 1)
			elseif operation == "adjust" then
				diagram_changed, status_line = apply_node_adjust(node, key, tonumber(raw_value) or 0)
			end
		end
	elseif scope == "visual" then
		local visual_node = get_visual_node(self.design_diagram, target_id)
		if visual_node ~= nil then
			if operation == "cycle" then
				diagram_changed, status_line = apply_visual_cycle(visual_node, key, tonumber(raw_value) or 1)
			elseif operation == "adjust" then
				diagram_changed, status_line = apply_visual_adjust(visual_node, key, tonumber(raw_value) or 0)
			end
		end
	elseif scope == "connection" then
		local connection = get_design_connection(self.design_diagram, target_id)
		if connection ~= nil then
			if operation == "cycle" then
				diagram_changed, status_line = apply_connection_cycle(connection, key, tonumber(raw_value) or 1)
			elseif operation == "adjust" then
				diagram_changed, status_line = apply_connection_adjust(connection, key, tonumber(raw_value) or 0)
			elseif operation == "toggle" then
				diagram_changed, status_line = apply_connection_toggle(connection, key)
			end
		end
	end

	if not diagram_changed then
		return false
	end

	sync_run_settings(self)
	restart_runtime(self)
	push_history_state(self)
	self.status_line = status_line or "Property updated."
	self.render_dirty = true
	return true
end

local function handle_command(self, command)
	local parts = split_command(command)
	if parts[1] == "prop_cycle" and #parts >= 5 then
		if mutate_property(self, "cycle", parts[2], parts[3] ~= "-" and parts[3] or nil, parts[4], parts[5]) then
			return
		end
	end
	if parts[1] == "prop_adjust" and #parts >= 5 then
		if mutate_property(self, "adjust", parts[2], parts[3] ~= "-" and parts[3] or nil, parts[4], parts[5]) then
			return
		end
	end
	if parts[1] == "prop_toggle" and #parts >= 4 then
		if mutate_property(self, "toggle", parts[2], parts[3] ~= "-" and parts[3] or nil, parts[4], nil) then
			return
		end
	end

	local tool_key = string.match(command or "", "^tool:(.+)$")
	if tool_key ~= nil then
		self.active_tool = tool_key
		self.link_from_node_id = nil
		self.status_line = "Tool selected: " .. tool_key
		self.render_dirty = true
		return
	end

	local diagram_key = string.match(command or "", "^load_diagram:(.+)$")
	if diagram_key ~= nil then
		load_named_diagram(self, diagram_key)
		return
	end

	local runs_delta = string.match(command or "", "^runs_delta:([+-]?%d+)$")
	if runs_delta ~= nil then
		local runs, visible = EditorActions.normalize_run_settings(
			(self.number_of_runs or DEFAULT_NUMBER_OF_RUNS) + tonumber(runs_delta),
			self.visible_runs or DEFAULT_VISIBLE_RUNS
		)
		self.number_of_runs = runs
		self.visible_runs = visible
		self.design_diagram.number_of_runs = runs
		self.design_diagram.visible_runs = visible
		self.status_line = string.format("Runs set to %d.", runs)
		self.render_dirty = true
		return
	end

	local visible_delta = string.match(command or "", "^visible_runs_delta:([+-]?%d+)$")
	if visible_delta ~= nil then
		local runs, visible = EditorActions.normalize_run_settings(
			self.number_of_runs or DEFAULT_NUMBER_OF_RUNS,
			(self.visible_runs or DEFAULT_VISIBLE_RUNS) + tonumber(visible_delta)
		)
		self.number_of_runs = runs
		self.visible_runs = visible
		self.design_diagram.number_of_runs = runs
		self.design_diagram.visible_runs = visible
		self.status_line = string.format("Visible runs set to %d.", visible)
		self.render_dirty = true
		return
	end

	if command == "step" then
		step_runtime(self)
		return
	end

	if command == "toggle_autoplay" then
		self.autoplay = not self.autoplay
		self.status_line = "Autoplay: " .. tostring(self.autoplay)
		self.render_dirty = true
		return
	end

	if command == "batch" then
		run_batch_simulation(self, self.number_of_runs, self.visible_runs)
		return
	end

	if command == "quick_run" then
		run_quick_simulation(self)
		return
	end

	if command == "multiple_runs" then
		run_batch_simulation(self, self.number_of_runs, self.visible_runs)
		return
	end

	if command == "autogen_next" then
		load_autogenerated_case(self)
		return
	end

	if command == "autoverify" then
		run_auto_verification(self)
		return
	end

	if command == "run_regressions" then
		run_regression_suite(self)
		return
	end

	if command == "select_all" then
		select_all_nodes(self)
		return
	end

	if command == "copy" then
		copy_selected_nodes(self)
		return
	end

	if command == "paste" then
		paste_selected_nodes(self)
		return
	end

	if command == "undo" then
		undo_editor_change(self)
		return
	end

	if command == "redo" then
		redo_editor_change(self)
		return
	end

	if command == "zoom_fit" then
		fit_camera_to_diagram(self)
		self.status_line = "Zoomed to fit diagram."
		self.render_dirty = true
		return
	end

	if command == "add_pool" then
		add_node(self, types.NODE.POOL)
		return
	end

	if command == "add_source" then
		add_node(self, types.NODE.SOURCE)
		return
	end

	if command == "add_gate" then
		add_node(self, types.NODE.GATE)
		return
	end

	if command == "add_drain" then
		add_node(self, types.NODE.DRAIN)
		return
	end

	if command == "add_queue" then
		add_node(self, types.NODE.QUEUE)
		return
	end

	if command == "add_delay" then
		add_node(self, types.NODE.DELAY)
		return
	end

	if command == "add_register" then
		add_node(self, types.NODE.REGISTER)
		return
	end

	if command == "arm_link" then
		if self.selected_node_id ~= nil and get_design_node(self.design_diagram, self.selected_node_id) ~= nil then
			self.link_from_node_id = self.selected_node_id
			self.status_line = "Link mode armed from " .. self.selected_node_id .. ". Click target node."
		else
			self.status_line = "Select functional node before arming link."
		end
		self.render_dirty = true
		return
	end

	if command == "delete_selected" then
		delete_selected_node(self)
		return
	end

	if command == "new_blank" then
		apply_design_diagram(self, build_blank_diagram(), "Created blank diagram.", true)
		self.current_diagram_key = nil
		return
	end

	if command == "reset" then
		reset_design_diagram(self)
		return
	end

	if command == "save" then
		save_editor_snapshot(self)
		return
	end

	if command == "export_selection" then
		export_selection_snapshot(self)
		return
	end

	if command == "save_svg" then
		save_diagram_svg(self)
		return
	end

	if command == "load" then
		local loaded = load_design_diagram(self, DEFAULT_DIAGRAM_PATH)
		if not loaded then
			local fallback = build_blank_diagram()
			apply_design_diagram(self, fallback, "Loaded fallback diagram.", true)
			self.current_diagram_key = detect_library_key_from_path(DEFAULT_DIAGRAM_PATH)
		end
		return
	end

	if command == "import" then
		load_design_diagram(self, LEGACY_SAMPLE_PATH)
		self.current_diagram_key = nil
		return
	end
end

get_selected_node_ids = function(self)
	local ordered = {}
	local seen = {}
	for _, node_id in ipairs(self.selected_node_ids or {}) do
		if not seen[node_id] and node_id_exists(self.design_diagram, node_id) then
			seen[node_id] = true
			ordered[#ordered + 1] = node_id
		end
	end
	if #ordered == 0 and self.selected_node_id ~= nil and node_id_exists(self.design_diagram, self.selected_node_id) then
		ordered[1] = self.selected_node_id
	end
	return ordered
end

set_selected_nodes = function(self, selected_ids, primary_selected_id)
	local ordered = {}
	local seen = {}
	for _, node_id in ipairs(selected_ids or {}) do
		if not seen[node_id] and node_id_exists(self.design_diagram, node_id) then
			seen[node_id] = true
			ordered[#ordered + 1] = node_id
		end
	end
	self.selected_node_ids = ordered
	self.selected_node_id = nil
	if primary_selected_id ~= nil and seen[primary_selected_id] then
		self.selected_node_id = primary_selected_id
	else
		self.selected_node_id = ordered[1]
	end
	self.selected_connection_id = nil
end

select_single_node = function(self, node_id)
	if node_id ~= nil and node_id_exists(self.design_diagram, node_id) then
		set_selected_nodes(self, { node_id }, node_id)
	else
		set_selected_nodes(self, {}, nil)
	end
end

select_single_connection = function(self, connection_id)
	self.selected_node_ids = {}
	self.selected_node_id = nil
	if connection_id ~= nil and (get_design_connection(self.design_diagram, connection_id) ~= nil or get_visual_connection(self.design_diagram, connection_id) ~= nil) then
		self.selected_connection_id = connection_id
	else
		self.selected_connection_id = nil
	end
end

sync_run_settings = function(self)
	local legacy_import = self.design_diagram and self.design_diagram.legacy_import or nil
	local runs = self.design_diagram.number_of_runs
	if runs == nil and type(legacy_import) == "table" then
		runs = legacy_import.number_of_runs
	end
	local visible_runs = self.design_diagram.visible_runs
	if visible_runs == nil and type(legacy_import) == "table" then
		visible_runs = legacy_import.visible_runs
	end
	runs, visible_runs = EditorActions.normalize_run_settings(
		runs or self.number_of_runs or DEFAULT_NUMBER_OF_RUNS,
		visible_runs or self.visible_runs or DEFAULT_VISIBLE_RUNS
	)
	self.number_of_runs = runs
	self.visible_runs = visible_runs
	self.design_diagram.number_of_runs = runs
	self.design_diagram.visible_runs = visible_runs
end

capture_history_snapshot = function(self)
	local snapshot = EditorActions.snapshot(
		self.design_diagram,
		self.editor_positions,
		get_selected_node_ids(self),
		self.selected_node_id,
		{
			x = self.camera_x,
			y = self.camera_y,
			zoom = self.camera_zoom,
		}
	)
	snapshot.selected_connection_id = self.selected_connection_id
	return snapshot
end

reset_history = function(self)
	self.history = EditorActions.new_history(capture_history_snapshot(self), HISTORY_LIMIT)
end

push_history_state = function(self)
	self.history = EditorActions.push_history(
		self.history or EditorActions.new_history(nil, HISTORY_LIMIT),
		capture_history_snapshot(self)
	)
end

local function handle_pointer_down(self, message)
	self.viewport_w = message.viewport_w or self.viewport_w
	self.viewport_h = message.viewport_h or self.viewport_h
	self.last_pointer_x = message.x or self.last_pointer_x
	self.last_pointer_y = message.y or self.last_pointer_y
	local active_tool = self.active_tool or "select"

	local button = message.button or "left"
	if button == "right" then
		self.panning = true
		self.dragging_node_id = nil
		return
	end

	local pointer_x = message.x or 0
	local pointer_y = message.y or 0

	if not is_inside_canvas(pointer_x, pointer_y, self.viewport_w, self.viewport_h) then
		self.dragging_node_id = nil
		self.panning = false
		return
	end

	if active_tool == "select" or active_tool == "resource" then
		local handle_id = find_handle_at(self, pointer_x, pointer_y, self.viewport_w, self.viewport_h)
		if handle_id ~= nil then
			select_single_node(self, handle_id)
			self.link_from_node_id = handle_id
			self.dragging_node_id = nil
			self.drag_node_moved = false
			self.panning = false
			self.status_line = "Link mode armed from " .. handle_id .. ". Click target node."
			self.render_dirty = true
			return
		end
	end

	local world_x, world_y = screen_to_world(
		self,
		pointer_x,
		pointer_y,
		self.viewport_w,
		self.viewport_h
	)

	local hit_id = find_node_at(self, world_x, world_y)
	local hit_design_node = hit_id ~= nil and get_design_node(self.design_diagram, hit_id) or nil
	local hit_connection_id = nil
	if hit_id == nil then
		hit_connection_id = find_connection_at(self, world_x, world_y)
	end

	if active_tool == "resource" then
		if self.link_from_node_id == nil then
			if hit_design_node ~= nil then
				select_single_node(self, hit_id)
				self.link_from_node_id = hit_id
				self.status_line = "Link mode armed from " .. hit_id .. ". Click target node."
			elseif hit_id ~= nil then
				self.status_line = "Resource connection tool requires functional nodes."
			else
				self.status_line = "Resource connection tool: click a source node."
			end
		elseif hit_design_node ~= nil and hit_id ~= self.link_from_node_id then
			local added = add_connection(self, self.link_from_node_id, hit_id)
			if added then
				self.status_line = "Added connection: " .. self.link_from_node_id .. " -> " .. hit_id
				select_single_node(self, hit_id)
				self.link_from_node_id = nil
				restart_runtime(self)
				push_history_state(self)
			else
				self.status_line = "Connection already exists."
			end
		elseif hit_id ~= nil then
			self.status_line = "Resource connection tool requires functional nodes."
		else
			self.status_line = "Link cancelled."
			self.link_from_node_id = nil
		end
		self.render_dirty = true
		return
	end

	if active_tool == "state" then
		if self.link_from_node_id == nil then
			if hit_design_node ~= nil then
				select_single_node(self, hit_id)
				self.link_from_node_id = hit_id
				self.status_line = "State link armed from " .. hit_id .. ". Click target node."
			elseif hit_id ~= nil then
				self.status_line = "State connection tool requires functional nodes."
			else
				self.status_line = "State connection tool: click a source node."
			end
		elseif hit_design_node ~= nil and hit_id ~= self.link_from_node_id then
			local added = add_connection(self, self.link_from_node_id, hit_id, types.CONNECTION.STATE, {
				action = types.STATE_ACTION.SET_ENABLED,
				source_field = types.STATE_FIELD.RESOURCES,
				comparator = types.COMPARATOR.GREATER,
				value = 0,
				scale = 1,
				target_enabled = true,
			})
			if added then
				self.status_line = "Added state connection: " .. self.link_from_node_id .. " => " .. hit_id
				select_single_node(self, hit_id)
				self.link_from_node_id = nil
				restart_runtime(self)
				push_history_state(self)
			else
				self.status_line = "State connection already exists."
			end
		elseif hit_id ~= nil then
			self.status_line = "State connection tool requires functional nodes."
		else
			self.status_line = "State link cancelled."
			self.link_from_node_id = nil
		end
		self.render_dirty = true
		return
	end

	local node_type = TOOL_TO_NODE_TYPE[active_tool]
	if node_type ~= nil then
		add_node(self, node_type, world_x, world_y)
		return
	end

	if active_tool == "text" then
		add_visual_node(self, "TextLabel", world_x, world_y)
		return
	end

	if active_tool == "group" then
		add_visual_node(self, "GroupBox", world_x, world_y)
		return
	end

	if active_tool == "chart" then
		add_visual_node(self, "Chart", world_x, world_y)
		return
	end

	if active_tool == "ap" then
		add_node(self, "artificial_player", world_x, world_y)
		return
	end

	if active_tool ~= "select" then
		self.status_line = "Tool not implemented yet: " .. tostring(active_tool)
		self.render_dirty = true
		return
	end

	if self.link_from_node_id ~= nil then
		if hit_design_node ~= nil and hit_id ~= self.link_from_node_id then
			local added = add_connection(self, self.link_from_node_id, hit_id)
			if added then
				self.status_line = "Added connection: " .. self.link_from_node_id .. " -> " .. hit_id
				self.link_from_node_id = nil
				restart_runtime(self)
				select_single_node(self, hit_id)
				push_history_state(self)
			else
				self.status_line = "Connection already exists."
			end
		elseif hit_id ~= nil then
			self.status_line = "Link target must be a functional node."
		else
			self.status_line = "Link cancelled."
			self.link_from_node_id = nil
		end
		self.render_dirty = true
		return
	end

	if hit_id ~= nil then
		select_single_node(self, hit_id)
	elseif hit_connection_id ~= nil then
		select_single_connection(self, hit_connection_id)
		self.dragging_node_id = nil
		self.drag_node_moved = false
		self.panning = false
		self.status_line = "Selected connection: " .. tostring(hit_connection_id)
		self.render_dirty = true
		return
	else
		select_single_node(self, nil)
	end

	if hit_id ~= nil then
		local pos = self.editor_positions[hit_id]
		if pos == nil then
			local visual_node = get_visual_node(self.design_diagram, hit_id)
			if visual_node ~= nil then
				local width, height = get_payload_dimensions(nil, visual_node)
				local center_x, center_y = resolve_visual_anchor_position(visual_node, width, height)
				pos = { x = center_x, y = center_y }
			end
		end
		self.dragging_node_id = hit_id
		self.drag_node_moved = false
		if pos ~= nil then
			self.drag_offset_x = pos.x - world_x
			self.drag_offset_y = pos.y - world_y
			self.panning = false
		else
			self.dragging_node_id = nil
			self.panning = false
		end
	else
		self.dragging_node_id = nil
		self.drag_node_moved = false
		self.panning = true
	end

	self.render_dirty = true
end

local function handle_pointer_move(self, message)
	self.viewport_w = message.viewport_w or self.viewport_w
	self.viewport_h = message.viewport_h or self.viewport_h

	local x = message.x or self.last_pointer_x
	local y = message.y or self.last_pointer_y
	local dx = message.dx
	local dy = message.dy
	if dx == nil then
		dx = x - self.last_pointer_x
	end
	if dy == nil then
		dy = y - self.last_pointer_y
	end

	if self.dragging_node_id ~= nil then
		local world_x, world_y = screen_to_world(self, x, y, self.viewport_w, self.viewport_h)
		local pos = self.editor_positions[self.dragging_node_id]
		if pos ~= nil then
			pos.x = world_x + self.drag_offset_x
			pos.y = world_y + self.drag_offset_y
			self.drag_node_moved = true
			self.render_dirty = true
		else
			local visual_node = get_visual_node(self.design_diagram, self.dragging_node_id)
			if visual_node ~= nil then
				set_visual_anchor_position(visual_node, world_x + self.drag_offset_x, world_y + self.drag_offset_y)
				self.drag_node_moved = true
				self.render_dirty = true
			end
		end
	elseif self.panning then
		self.camera_x = self.camera_x - dx / self.camera_zoom
		self.camera_y = self.camera_y - dy / self.camera_zoom
		self.render_dirty = true
	end

	self.last_pointer_x = x
	self.last_pointer_y = y
end

local function handle_pointer_up(self, message)
	local should_commit_drag = self.dragging_node_id ~= nil and self.drag_node_moved == true
	self.dragging_node_id = nil
	self.drag_node_moved = false
	self.panning = false
	self.last_pointer_x = message.x or self.last_pointer_x
	self.last_pointer_y = message.y or self.last_pointer_y
	if should_commit_drag then
		push_history_state(self)
	end
	self.render_dirty = true
end

local function handle_pointer_wheel(self, message)
	local delta = message.delta or 0
	if delta == 0 then
		return
	end

	local pointer_x = message.x or self.last_pointer_x
	local pointer_y = message.y or self.last_pointer_y
	if not is_inside_canvas(pointer_x, pointer_y, self.viewport_w, self.viewport_h) then
		return
	end

	local zoom_factor = 1 + delta * 0.12
	self.camera_zoom = clamp(self.camera_zoom * zoom_factor, 0.2, 4.0)
	self.render_dirty = true
end

local function handle_pointer_message(self, message)
	if message.phase == "down" then
		handle_pointer_down(self, message)
	elseif message.phase == "move" then
		handle_pointer_move(self, message)
	elseif message.phase == "up" then
		handle_pointer_up(self, message)
	elseif message.phase == "wheel" then
		handle_pointer_wheel(self, message)
	end
end

function init(self)
	msg.post(".", "acquire_input_focus")

	self.seed = 17
	self.camera_x = 0
	self.camera_y = 0
	self.camera_zoom = 0.9
	self.viewport_w = DEFAULT_VIEWPORT_W
	self.viewport_h = DEFAULT_VIEWPORT_H
	self.autoplay = false
	self.autoplay_accum = 0
	self.dragging_node_id = nil
	self.drag_offset_x = 0
	self.drag_offset_y = 0
	self.panning = false
	self.last_pointer_x = 0
	self.last_pointer_y = 0
	self.selected_node_id = nil
	self.selected_node_ids = {}
	self.selected_connection_id = nil
	self.link_from_node_id = nil
	self.active_tool = "select"
	self.status_line = ""
	self.last_batch_summary = ""
	self.last_batch_distribution = nil
	self.last_accuracy_text = nil
	self.last_batch_chart_points = nil
	self.last_regression_report = nil
	self.last_autogen_report = nil
	self.last_step_summary = nil
	self.render_dirty = true
	self.design_diagram = nil
	self.initial_diagram = nil
	self.current_diagram_key = nil
	self.editor_positions = {}
	self.runtime_state = nil
	self.autogen_case_index = 0
	self.number_of_runs = DEFAULT_NUMBER_OF_RUNS
	self.visible_runs = DEFAULT_VISIBLE_RUNS
	self.clipboard = nil
	self.paste_shift = 0
	self.history = EditorActions.new_history(nil, HISTORY_LIMIT)

	local loaded = false
	if file_exists(DEFAULT_DIAGRAM_PATH) then
		local ok, result = pcall(load_design_diagram, self, DEFAULT_DIAGRAM_PATH)
		if ok then
			loaded = result
		else
			self.status_line = "Load bootstrap failed: " .. tostring(result)
		end
	end
	if not loaded then
		local fallback = build_blank_diagram()
		local ok, err = pcall(apply_design_diagram, self, fallback, "Loaded fallback diagram.", true)
		if ok then
			self.current_diagram_key = detect_library_key_from_path(DEFAULT_DIAGRAM_PATH)
		else
			self.status_line = "Fallback bootstrap failed: " .. tostring(err)
		end
	end

	local regressions_ok, regressions_err = pcall(run_regression_suite, self)
	if not regressions_ok then
		self.status_line = "Regression bootstrap failed: " .. tostring(regressions_err)
	end
	if self.last_regression_report ~= nil then
		print(string.format(
			"machinations_editor: regressions %d/%d passed",
			self.last_regression_report.passed or 0,
			self.last_regression_report.total or 0
		))
	end

	self.status_line = "Editor ready. Use Graph/Edit/File/Run tabs for legacy actions. P builds a generated case, U verifies the generated suite."
	if self.last_regression_report ~= nil then
		self.status_line = self.status_line .. string.format(
			" Regressions %d/%d.",
			self.last_regression_report.passed or 0,
			self.last_regression_report.total or 0
		)
	end
	self.render_dirty = true
	print("machinations_editor: initialized")
end

function update(self, dt)
	if self.autoplay and self.runtime_state ~= nil and not self.runtime_state.ended then
		self.autoplay_accum = self.autoplay_accum + dt
		while self.autoplay_accum >= AUTOSTEP_INTERVAL do
			self.autoplay_accum = self.autoplay_accum - AUTOSTEP_INTERVAL
			step_runtime(self)
			if not self.autoplay then
				break
			end
		end
	end

	send_render(self)
end

function on_message(self, message_id, message, sender)
	if message_id == MSG_EDITOR_POINTER then
		handle_pointer_message(self, message)
	elseif message_id == MSG_EDITOR_COMMAND then
		handle_command(self, message.command)
	end
end

function on_reload(self)
	self.render_dirty = true
end
